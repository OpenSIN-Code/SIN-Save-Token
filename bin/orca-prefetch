#!/usr/bin/env python3
"""orca-prefetch — STUB: warm the next likely task while the current one runs.

Intended behavior (not fully implemented):
  - Given a queue / next-task hint, call cache-warm + optional cheap agent ping
    so the subsequent handoff is already cache-hot.
  - Non-blocking: returns immediately after scheduling.

Usage:
  orca-prefetch --help
  orca-prefetch "next: implement router tests" --dry-run
  orca-prefetch --from-file queue.txt

Exit 0. Fail-open. No real prefetch network in stub unless --live (not implemented).
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(
        prog="orca-prefetch",
        description="STUB: prefetch/warm the next task while current work runs.",
    )
    ap.add_argument("task", nargs="*", help="Next-task description")
    ap.add_argument("--from-file", dest="from_file", help="Read next task from file")
    ap.add_argument("--dry-run", action="store_true", help="Show plan only")
    ap.add_argument(
        "--live",
        action="store_true",
        help="Reserved for real prefetch (not implemented — falls back to dry).",
    )
    args = ap.parse_args(argv)

    text = " ".join(args.task).strip()
    if args.from_file:
        try:
            text = Path(args.from_file).read_text(encoding="utf-8", errors="replace").strip()
        except OSError as e:
            print(f"orca-prefetch: warn {e}", file=sys.stderr)
            return 0

    if not text:
        ap.print_help()
        print("\n[stub] Provide a next-task string or --from-file.", file=sys.stderr)
        return 0

    preview = text.replace("\n", " ")[:160]
    print(f"orca-prefetch: stub would warm next_task={preview!r}")
    print("orca-prefetch: plan steps=cache-warm → optional cheap agent ping (not spawned)")
    if args.live:
        print(
            "orca-prefetch: --live ignored in stub; use bin/cache-warm directly.",
            file=sys.stderr,
        )
    return 0


if __name__ == "__main__":
    sys.exit(main())
