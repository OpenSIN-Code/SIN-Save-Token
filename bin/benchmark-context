#!/usr/bin/env python3
"""Reproducible A/B/C benchmark for context retrieval cost and quality.

The benchmark never invents a baseline. Commands for the unspecialized baseline
and the deliberately full stack must be supplied explicitly so the same agent,
model and task can be compared honestly against sin-context.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import platform
import re
import shlex
import subprocess
import sys
import tempfile
import time
from dataclasses import asdict, dataclass
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parent.parent
DEFAULT_TASKS = ROOT / "config" / "benchmark-tasks.json"
DEFAULT_OUTPUT_DIR = ROOT / ".sin" / "audit"
SIN_CONTEXT = ROOT / "bin" / "sin-context"
SENSITIVE_NAME = re.compile(
    r"(?i)(token|secret|password|passwd|api[_-]?key|authorization|cookie)"
)
AUTHORIZATION_HEADER = re.compile(
    r"(?im)\bAuthorization\s*:\s*[^\r\n]+"
)
BEARER_VALUE = re.compile(r"(?i)\bBearer\s+[A-Za-z0-9._~+/=-]+")
SENSITIVE_ASSIGNMENT = re.compile(
    r"(?i)\b(token|secret|password|passwd|api[_-]?key|authorization|cookie)\b"
    r"(\s*[:=]\s*)([^\s,;]+)"
)
URL_CREDENTIALS = re.compile(r"(https?://[^:/\s]+:)[^@/\s]+@", re.IGNORECASE)


def safe_subprocess_environment() -> dict[str, str]:
    environment = os.environ.copy()
    environment.pop("SIN_MANIFEST_HMAC_KEY", None)
    return environment


def ensure_text(value: str | bytes | None) -> str:
    if value is None:
        return ""
    if isinstance(value, bytes):
        return value.decode("utf-8", errors="replace")
    return value


def redact_sensitive_text(text: str) -> str:
    redacted = AUTHORIZATION_HEADER.sub(
        "Authorization: <redacted>",
        text,
    )
    redacted = BEARER_VALUE.sub("Bearer <redacted>", redacted)
    redacted = SENSITIVE_ASSIGNMENT.sub(r"\1\2<redacted>", redacted)
    return URL_CREDENTIALS.sub(r"\1<redacted>@", redacted)


def redact_argv(argv: list[str]) -> list[str]:
    redacted: list[str] = []
    hide_next = False
    for item in argv:
        if hide_next:
            redacted.append("<redacted>")
            hide_next = False
            continue
        if item.startswith("-") and SENSITIVE_NAME.search(item):
            if "=" in item:
                name, _ = item.split("=", 1)
                redacted.append(f"{name}=<redacted>")
            else:
                redacted.append(item)
                hide_next = True
            continue
        redacted.append(redact_sensitive_text(item))
    return redacted


def persisted_command_summary(argv: list[str]) -> list[str]:
    if not argv:
        return []
    executable = redact_sensitive_text(argv[0])
    return [executable, f"<{max(0, len(argv) - 1)} arguments omitted>"]


@dataclass
class RunResult:
    task_id: str
    mode: str
    repetition: int
    command: list[str]
    exit_code: int
    duration_ms: int
    success: bool
    expected_match: str | None
    stdout_chars: int
    stderr_chars: int
    approx_output_tokens: int
    provider: str | None = None
    cached: bool | None = None
    reported_approx_tokens: int | None = None
    input_tokens: int | None = None
    cache_read_tokens: int | None = None
    cache_write_tokens: int | None = None
    reported_output_tokens: int | None = None
    provider_attempts: int | None = None
    telemetry_cache_hit: bool | None = None


def approximate_tokens(text: str) -> int:
    return max(0, (len(text) + 2) // 3)


def load_tasks(path: Path) -> list[dict[str, Any]]:
    document = json.loads(path.read_text(encoding="utf-8"))
    tasks = document.get("tasks")
    if not isinstance(tasks, list) or not tasks:
        raise ValueError("benchmark task file requires a non-empty tasks array")

    normalized: list[dict[str, Any]] = []
    seen: set[str] = set()
    for item in tasks:
        if not isinstance(item, dict):
            raise ValueError("each benchmark task must be an object")
        task_id = str(item.get("id", "")).strip()
        query = str(item.get("query", "")).strip()
        expected = item.get("expected_any", [])
        if not task_id or not query:
            raise ValueError("each benchmark task requires id and query")
        if task_id in seen:
            raise ValueError(f"duplicate benchmark task id: {task_id}")
        if not isinstance(expected, list) or not all(
            isinstance(marker, str) and marker for marker in expected
        ):
            raise ValueError(f"task {task_id}: expected_any must be a string list")
        seen.add(task_id)
        normalized.append(
            {"id": task_id, "query": query, "expected_any": expected}
        )
    return normalized


def render_external_command(template: str, *, query: str, cwd: Path) -> list[str]:
    rendered = template.format(query=query, cwd=str(cwd))
    argv = shlex.split(rendered)
    if not argv:
        raise ValueError("rendered benchmark command is empty")
    return argv


def sin_context_command(
    *,
    query: str,
    cwd: Path,
    cache: Path,
    health: Path,
    no_cache: bool,
) -> list[str]:
    argv = [
        sys.executable,
        str(SIN_CONTEXT),
        query,
        "--cwd",
        str(cwd),
        "--cache",
        str(cache),
        "--provider-health",
        str(health),
        "--json",
    ]
    if no_cache:
        argv.append("--no-cache")
    return argv


def parse_json_payload(stdout: str) -> dict[str, Any]:
    try:
        payload = json.loads(stdout)
    except json.JSONDecodeError:
        return {}
    return payload if isinstance(payload, dict) else {}


def parse_sin_context_metadata(
    stdout: str,
) -> tuple[str | None, bool | None, int | None, int | None]:
    payload = parse_json_payload(stdout)
    provider = payload.get("provider")
    cached = payload.get("cached")
    approx = payload.get("approx_tokens")
    attempts = payload.get("attempts")
    return (
        str(provider) if provider else None,
        bool(cached) if isinstance(cached, bool) else None,
        int(approx) if isinstance(approx, int) else None,
        len(attempts) if isinstance(attempts, list) else None,
    )


def parse_benchmark_telemetry(stdout: str) -> dict[str, Any]:
    payload = parse_json_payload(stdout)
    metrics = payload.get("benchmark_metrics")
    if not isinstance(metrics, dict):
        return {}

    result: dict[str, Any] = {}
    for name in (
        "input_tokens",
        "cache_read_tokens",
        "cache_write_tokens",
        "output_tokens",
        "provider_attempts",
    ):
        value = metrics.get(name)
        if isinstance(value, int) and not isinstance(value, bool) and value >= 0:
            result[name] = value
    cache_hit = metrics.get("cache_hit")
    if isinstance(cache_hit, bool):
        result["cache_hit"] = cache_hit
    return result


def evaluate_success(
    *,
    exit_code: int,
    stdout: str,
    expected_any: list[str],
) -> tuple[bool, str | None]:
    lowered = stdout.lower()
    for marker in expected_any:
        if marker.lower() in lowered:
            return exit_code == 0, marker
    if expected_any:
        return False, None
    return exit_code == 0 and bool(stdout.strip()), None


def execute(
    *,
    task: dict[str, Any],
    mode: str,
    repetition: int,
    argv: list[str],
    cwd: Path,
    timeout_seconds: int,
) -> RunResult:
    started = time.monotonic()
    try:
        process = subprocess.run(
            argv,
            cwd=cwd,
            text=True,
            capture_output=True,
            timeout=timeout_seconds,
            check=False,
            env=safe_subprocess_environment(),
        )
        exit_code = process.returncode
        stdout = process.stdout
        stderr = process.stderr
    except subprocess.TimeoutExpired as error:
        exit_code = 124
        stdout = ensure_text(error.stdout)
        stderr = ensure_text(error.stderr)
        stderr += "\nbenchmark timeout"
    except OSError as error:
        exit_code = 127
        stdout = ""
        stderr = str(error)

    duration_ms = int((time.monotonic() - started) * 1000)
    success, marker = evaluate_success(
        exit_code=exit_code,
        stdout=stdout,
        expected_any=task["expected_any"],
    )
    provider = cached = reported = attempts = None
    if mode.startswith("sst-"):
        provider, cached, reported, attempts = parse_sin_context_metadata(stdout)
    telemetry = parse_benchmark_telemetry(stdout)

    return RunResult(
        task_id=task["id"],
        mode=mode,
        repetition=repetition,
        command=persisted_command_summary(argv),
        exit_code=exit_code,
        duration_ms=duration_ms,
        success=success,
        expected_match=marker,
        stdout_chars=len(stdout),
        stderr_chars=len(stderr),
        approx_output_tokens=approximate_tokens(stdout),
        provider=provider,
        cached=cached,
        reported_approx_tokens=reported,
        input_tokens=telemetry.get("input_tokens"),
        cache_read_tokens=telemetry.get("cache_read_tokens"),
        cache_write_tokens=telemetry.get("cache_write_tokens"),
        reported_output_tokens=telemetry.get("output_tokens"),
        provider_attempts=(
            telemetry.get("provider_attempts")
            if telemetry.get("provider_attempts") is not None
            else attempts
        ),
        telemetry_cache_hit=(
            telemetry.get("cache_hit")
            if telemetry.get("cache_hit") is not None
            else cached
        ),
    )


def summarize(results: list[RunResult]) -> dict[str, Any]:
    summary: dict[str, Any] = {}
    modes = sorted({result.mode for result in results})
    for mode in modes:
        selected = [result for result in results if result.mode == mode]
        durations = sorted(result.duration_ms for result in selected)
        tokens = sorted(result.approx_output_tokens for result in selected)
        successes = sum(1 for result in selected if result.success)
        middle = len(selected) // 2
        summary[mode] = {
            "runs": len(selected),
            "successes": successes,
            "success_rate": successes / len(selected) if selected else 0.0,
            "duration_ms_total": sum(durations),
            "duration_ms_median": durations[middle] if durations else None,
            "approx_output_tokens_total": sum(tokens),
            "approx_output_tokens_median": tokens[middle] if tokens else None,
        }
    return summary


VARIANT_MODES = {
    "baseline": "baseline",
    "sst": "sst-cold",
    "full_stack": "full-stack",
}


def benchmark_task_set_hash(tasks: list[dict[str, Any]]) -> str:
    canonical = json.dumps(
        tasks,
        ensure_ascii=False,
        sort_keys=True,
        separators=(",", ":"),
    )
    return hashlib.sha256(canonical.encode("utf-8")).hexdigest()


def comparable_task_id(result: RunResult) -> str:
    return f"{result.task_id}#r{result.repetition}"


def contract_metrics(result: RunResult) -> dict[str, Any]:
    if result.reported_output_tokens is not None:
        output_tokens = result.reported_output_tokens
        output_source = "reported"
    elif result.reported_approx_tokens is not None:
        output_tokens = result.reported_approx_tokens
        output_source = "sin-context-approximation"
    else:
        output_tokens = result.approx_output_tokens
        output_source = "character-approximation"

    return {
        "input_tokens": result.input_tokens,
        "cache_read_tokens": result.cache_read_tokens,
        "cache_write_tokens": result.cache_write_tokens,
        "output_tokens": output_tokens,
        "duration_ms": result.duration_ms,
        "success": result.success,
        "provider_attempts": result.provider_attempts,
        "cache_hit": result.telemetry_cache_hit,
        "output_tokens_source": output_source,
    }


def contract_run(result: RunResult, variant: str) -> dict[str, Any]:
    return {
        "task_id": comparable_task_id(result),
        "variant": variant,
        "metrics": contract_metrics(result),
        "evidence": {
            "mode": result.mode,
            "repetition": result.repetition,
            "exit_code": result.exit_code,
            "expected_match": result.expected_match,
            "provider": result.provider,
            "stdout_chars": result.stdout_chars,
            "stderr_chars": result.stderr_chars,
            "command": result.command,
        },
    }


def exact_metric_telemetry_complete(result: RunResult) -> bool:
    numeric = (
        result.input_tokens,
        result.cache_read_tokens,
        result.cache_write_tokens,
        result.reported_output_tokens,
        result.provider_attempts,
    )
    return all(
        isinstance(value, int) and not isinstance(value, bool) and value >= 0
        for value in numeric
    ) and isinstance(result.telemetry_cache_hit, bool)


def build_report(
    *,
    results: list[RunResult],
    tasks: list[dict[str, Any]],
    cwd: Path,
    tasks_path: Path,
    repetitions: int,
    missing_modes: list[str],
) -> dict[str, Any]:
    selected: dict[str, list[RunResult]] = {
        variant: [result for result in results if result.mode == mode]
        for variant, mode in VARIANT_MODES.items()
    }
    variants = {
        variant: {
            "runs": [contract_run(result, variant) for result in runs]
        }
        for variant, runs in selected.items()
    }

    errors: list[str] = []
    if missing_modes:
        errors.append(
            "missing comparable variants: "
            + ", ".join(sorted(missing_modes))
        )

    task_sets: list[set[str]] = []
    for variant, runs in selected.items():
        task_ids = [comparable_task_id(result) for result in runs]
        if not task_ids:
            errors.append(f"variant {variant} has no comparable runs")
        if len(task_ids) != len(set(task_ids)):
            errors.append(f"variant {variant} contains duplicate task IDs")
        task_sets.append(set(task_ids))

    if task_sets and any(task_set != task_sets[0] for task_set in task_sets[1:]):
        errors.append("comparable variants do not contain identical task sets")

    failed = [
        f"{variant}:{comparable_task_id(result)}"
        for variant, runs in selected.items()
        for result in runs
        if not result.success
    ]
    if failed:
        errors.append(
            "unsuccessful comparable runs: "
            + ", ".join(failed[:10])
            + (" …" if len(failed) > 10 else "")
        )

    incomplete = [
        f"{variant}:{comparable_task_id(result)}"
        for variant, runs in selected.items()
        for result in runs
        if not exact_metric_telemetry_complete(result)
    ]
    if incomplete:
        errors.append(
            "exact token/cache telemetry missing: "
            + ", ".join(incomplete[:10])
            + (" …" if len(incomplete) > 10 else "")
        )

    return {
        "schema_version": 1,
        "generated_at": time.strftime(
            "%Y-%m-%dT%H:%M:%SZ",
            time.gmtime(),
        ),
        "claimable_abc_comparison": not errors,
        "task_set_hash": benchmark_task_set_hash(tasks),
        "variants": variants,
        "errors": errors,
        "environment": {
            "python": sys.version,
            "platform": platform.platform(),
        },
        "repository": str(cwd),
        "tasks_file": str(tasks_path),
        "repetitions": repetitions,
        "summary": summarize(results),
        "supplemental": {
            "sst_warm": {
                "runs": [
                    contract_run(result, "sst")
                    for result in results
                    if result.mode == "sst-warm"
                ]
            }
        },
        "legacy_runs": [asdict(result) for result in results],
    }


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--tasks", type=Path, default=DEFAULT_TASKS)
    parser.add_argument("--cwd", type=Path, default=ROOT)
    parser.add_argument("--out", type=Path)
    parser.add_argument("--repetitions", type=int, default=1)
    parser.add_argument("--timeout-seconds", type=int, default=180)
    parser.add_argument(
        "--baseline-command",
        default=os.environ.get("SST_BENCH_BASELINE_COMMAND", ""),
        help="command template for no-SST run; supports {query} and {cwd}",
    )
    parser.add_argument(
        "--full-stack-command",
        default=os.environ.get("SST_BENCH_FULL_STACK_COMMAND", ""),
        help="command template for all-systems run; supports {query} and {cwd}",
    )
    parser.add_argument(
        "--allow-partial",
        action="store_true",
        help="record SST-only results when external A/C commands are unavailable",
    )
    args = parser.parse_args()

    if args.repetitions < 1:
        parser.error("--repetitions must be at least 1")

    cwd = args.cwd.resolve()
    tasks = load_tasks(args.tasks.resolve())
    missing_modes = []
    if not args.baseline_command:
        missing_modes.append("baseline")
    if not args.full_stack_command:
        missing_modes.append("full-stack")
    if missing_modes and not args.allow_partial:
        print(
            "Missing required comparable commands: " + ", ".join(missing_modes),
            file=sys.stderr,
        )
        print(
            "Set SST_BENCH_BASELINE_COMMAND and SST_BENCH_FULL_STACK_COMMAND "
            "or pass --allow-partial for a non-claimable SST smoke benchmark.",
            file=sys.stderr,
        )
        return 2

    results: list[RunResult] = []
    with tempfile.TemporaryDirectory(prefix="sst-benchmark-") as temporary:
        temp = Path(temporary)
        for repetition in range(1, args.repetitions + 1):
            for task in tasks:
                if args.baseline_command:
                    results.append(
                        execute(
                            task=task,
                            mode="baseline",
                            repetition=repetition,
                            argv=render_external_command(
                                args.baseline_command,
                                query=task["query"],
                                cwd=cwd,
                            ),
                            cwd=cwd,
                            timeout_seconds=args.timeout_seconds,
                        )
                    )

                cold_cache = temp / f"cold-{repetition}-{task['id']}.sqlite3"
                cold_health = temp / f"health-{repetition}-{task['id']}.sqlite3"
                results.append(
                    execute(
                        task=task,
                        mode="sst-cold",
                        repetition=repetition,
                        argv=sin_context_command(
                            query=task["query"],
                            cwd=cwd,
                            cache=cold_cache,
                            health=cold_health,
                            no_cache=True,
                        ),
                        cwd=cwd,
                        timeout_seconds=args.timeout_seconds,
                    )
                )

                warm_cache = temp / f"warm-{repetition}-{task['id']}.sqlite3"
                warm_health = temp / f"warm-health-{repetition}-{task['id']}.sqlite3"
                warmup = sin_context_command(
                    query=task["query"],
                    cwd=cwd,
                    cache=warm_cache,
                    health=warm_health,
                    no_cache=False,
                )
                execute(
                    task=task,
                    mode="sst-warmup",
                    repetition=repetition,
                    argv=warmup,
                    cwd=cwd,
                    timeout_seconds=args.timeout_seconds,
                )
                results.append(
                    execute(
                        task=task,
                        mode="sst-warm",
                        repetition=repetition,
                        argv=warmup,
                        cwd=cwd,
                        timeout_seconds=args.timeout_seconds,
                    )
                )

                if args.full_stack_command:
                    results.append(
                        execute(
                            task=task,
                            mode="full-stack",
                            repetition=repetition,
                            argv=render_external_command(
                                args.full_stack_command,
                                query=task["query"],
                                cwd=cwd,
                            ),
                            cwd=cwd,
                            timeout_seconds=args.timeout_seconds,
                        )
                    )

    timestamp = time.strftime("%Y%m%d-%H%M%S", time.gmtime())
    output = args.out or DEFAULT_OUTPUT_DIR / f"context-benchmark-{timestamp}.json"
    output = output.resolve()
    output.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    try:
        output.parent.chmod(0o700)
    except OSError:
        pass

    report = build_report(
        results=results,
        tasks=tasks,
        cwd=cwd,
        tasks_path=args.tasks.resolve(),
        repetitions=args.repetitions,
        missing_modes=missing_modes,
    )
    output.write_text(
        json.dumps(report, ensure_ascii=False, indent=2) + "\n",
        encoding="utf-8",
    )
    try:
        output.chmod(0o600)
    except OSError:
        pass
    print(output)

    required_modes = {"sst-cold", "sst-warm"}
    if not missing_modes:
        required_modes |= {"baseline", "full-stack"}
    failed = [
        result
        for result in results
        if result.mode in required_modes and not result.success
    ]
    if failed:
        return 1
    if missing_modes:
        # Explicit --allow-partial is a smoke run only. The report itself
        # remains claimable_abc_comparison=false and contains the reasons.
        return 0
    return 0 if report["claimable_abc_comparison"] is True else 1


if __name__ == "__main__":
    raise SystemExit(main())
