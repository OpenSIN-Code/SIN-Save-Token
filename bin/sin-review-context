#!/usr/bin/env python3
"""sin-review-context – Review-Sensor CLI."""

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

from sin_review_context import ReviewContextBuilder, build_blind_review_packet


def command_build(args: argparse.Namespace) -> int:
    worktree = Path(args.worktree)
    builder = ReviewContextBuilder(worktree)
    ctx = builder.build_review_context(args.base_sha)
    print(json.dumps(ctx, indent=2))
    return 0


def command_blind_packet(args: argparse.Namespace) -> int:
    with open(args.task_file, encoding="utf-8") as f:
        task = json.load(f)
    with open(args.review_context_file, encoding="utf-8") as f:
        review_ctx = json.load(f)
    diff = ""
    if args.diff_file:
        with open(args.diff_file, encoding="utf-8") as f:
            diff = f.read()

    packet = build_blind_review_packet(task, review_ctx, diff)
    print(json.dumps(packet, indent=2))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="sin-review-context", description="Review-Sensor CLI")
    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("build")
    p.add_argument("worktree")
    p.add_argument("--base-sha", default="HEAD")

    p = sub.add_parser("blind-packet")
    p.add_argument("task_file")
    p.add_argument("review_context_file")
    p.add_argument("--diff-file")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return 1

    return {"build": command_build, "blind-packet": command_blind_packet}[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
