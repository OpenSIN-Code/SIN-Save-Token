#!/usr/bin/env python3
"""orca-router — classify a task description → agent + model (no spawn).

Routing rule (owner-fixed):
  trivial / default → mimo-code | opencode  (cheap)
  heavy             → codex with model gpt-5.6-sol

Usage:
  orca-router "fix the typo in README"
  orca-router --explain "refactor auth across 12 files"
  echo "migrate postgres schema" | orca-router
  orca-router --help

stdout (machine-readable, single line):
  agent=<mimo-code|opencode|codex> model=<gpt-5.6-sol|->

Env:
  ORCA_DEFAULT_CHEAP=mimo-code|opencode   (default: mimo-code)
  ORCA_HEAVY_MODEL=gpt-5.6-sol            (default: gpt-5.6-sol)

No network. No spawn. Exit 0 always (empty input → default cheap).
"""
from __future__ import annotations

import argparse
import os
import re
import sys

HEAVY_MODEL_DEFAULT = "gpt-5.6-sol"

# Keywords that push toward heavy (codex).
HEAVY_KW = re.compile(
    r"\b("
    r"build|rebuild|refactor|rearchitect|architecture|audit|migrate|migration|"
    r"multi[- ]?file|redesign|rewrite|implement|security|overhaul|benchmark|"
    r"performance|optimize\s+system|full[- ]?stack|end[- ]?to[- ]?end|e2e|"
    r"large|complex|subsystem|infra|infrastructure|deploy\s+pipeline|"
    r"breaking\s+change|cross[- ]?cutting|system[- ]?wide"
    r")\b",
    re.I,
)

# Keywords that push toward trivial/cheap.
TRIVIAL_KW = re.compile(
    r"\b("
    r"read|lint|rename|typo|status|help|list|show|cat|grep|check|smoke|"
    r"1[- ]?file|single[- ]?file|one[- ]?file|docs?|comment|format|"
    r"prettier|eslint|typecheck|dry[- ]?run|version|ping|warmup|warm"
    r")\b",
    re.I,
)

# Explicit multi-file signals
MULTI_FILE = re.compile(
    r"\b(\d+)\s+files?\b|\bacross\s+\d+|\bmultiple\s+files?\b|\bmany\s+files?\b",
    re.I,
)


def default_cheap() -> str:
    v = (os.environ.get("ORCA_DEFAULT_CHEAP") or "mimo-code").strip().lower()
    if v in ("mimo-code", "mimo", "opencode"):
        return "opencode" if v == "opencode" else "mimo-code"
    return "mimo-code"


def heavy_model() -> str:
    return (os.environ.get("ORCA_HEAVY_MODEL") or HEAVY_MODEL_DEFAULT).strip() or HEAVY_MODEL_DEFAULT


def classify(text: str) -> tuple[str, str, list[str]]:
    """Return (agent, model, reasons)."""
    reasons: list[str] = []
    t = (text or "").strip()
    if not t:
        reasons.append("empty input → default cheap")
        return default_cheap(), "-", reasons

    score = 0  # >0 heavy, <0 trivial
    low = t.lower()

    if HEAVY_KW.search(t):
        hits = HEAVY_KW.findall(t)
        score += 2 + min(3, len(hits))
        reasons.append(f"heavy keywords: {', '.join(dict.fromkeys(h.lower() if isinstance(h, str) else h[0].lower() for h in hits))}")

    if TRIVIAL_KW.search(t):
        hits = TRIVIAL_KW.findall(t)
        score -= 2 + min(2, len(hits))
        reasons.append(f"trivial keywords: {', '.join(dict.fromkeys(h.lower() if isinstance(h, str) else h[0].lower() for h in hits))}")

    m = MULTI_FILE.search(t)
    if m:
        score += 3
        reasons.append(f"multi-file signal: {m.group(0)!r}")

    # Length / scope heuristic
    words = re.findall(r"\w+", t)
    n = len(words)
    if n >= 40:
        score += 2
        reasons.append(f"long brief ({n} words)")
    elif n <= 8 and score <= 0:
        score -= 1
        reasons.append(f"short brief ({n} words)")

    # Path enumeration: many path-like tokens → heavy
    paths = re.findall(r"[\w./-]+\.(?:py|js|ts|tsx|rs|go|md|json|yml|yaml|sh|toml)", t)
    if len(paths) >= 3:
        score += 2
        reasons.append(f"{len(paths)} file paths mentioned")
    elif len(paths) == 1 and score <= 0:
        score -= 1
        reasons.append("single file path")

    # Explicit agent hints in the task text (owner override light)
    if re.search(r"\b(use\s+)?codex\b|\bgpt-5\.6-sol\b|\bheavy\b", low):
        score += 4
        reasons.append("explicit heavy/codex hint")
    if re.search(r"\b(use\s+)?(mimo-code|opencode|cheap|trivial)\b", low):
        score -= 3
        reasons.append("explicit cheap-agent hint")

    if score >= 2:
        reasons.append(f"score={score} → heavy")
        return "codex", heavy_model(), reasons

    reasons.append(f"score={score} → cheap")
    return default_cheap(), "-", reasons


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(
        prog="orca-router",
        description="Classify task → agent=… model=… (routing only, no spawn).",
    )
    ap.add_argument("task", nargs="*", help="Task description (or stdin)")
    ap.add_argument(
        "--explain",
        action="store_true",
        help="Print routing reasons on stderr (stdout stays machine-readable).",
    )
    ap.add_argument(
        "--dry-run",
        action="store_true",
        help="Same as normal classify (no side effects).",
    )
    ap.add_argument(
        "--json",
        action="store_true",
        help="Emit JSON object instead of key=value line.",
    )
    args = ap.parse_args(argv)

    if args.task:
        text = " ".join(args.task)
    elif not sys.stdin.isatty():
        text = sys.stdin.read()
    else:
        text = ""

    agent, model, reasons = classify(text)

    if args.explain:
        for r in reasons:
            print(f"  reason: {r}", file=sys.stderr)

    if args.json:
        import json

        print(json.dumps({"agent": agent, "model": model, "reasons": reasons}))
    else:
        print(f"agent={agent} model={model}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
