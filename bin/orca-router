#!/usr/bin/env python3
"""orca-router — classify a task description → worker role + suggested agent.

This is a role classifier, NOT an agent router.
Codex decides which agent to use. This only suggests a worker role.

Usage:
  orca-router "fix the typo in README"
  orca-router --explain "refactor auth across 12 files"
  echo "migrate postgres schema" | orca-router
  orca-router --help

stdout (machine-readable, single line):
  role=<explorer|librarian|implementer|reviewer> agent=<mimo-code|opencode|kilo-code>

Env:
  ORCA_DEFAULT_EXPLORER=mimo-code   (default: mimo-code)
  ORCA_DEFAULT_IMPLEMENTER=opencode (default: opencode)
"""

from __future__ import annotations

import argparse
import os
import re
import sys

DEFAULT_EXPLORER = os.environ.get("ORCA_DEFAULT_EXPLORER", "mimo-code")
DEFAULT_IMPLEMENTER = os.environ.get("ORCA_DEFAULT_IMPLEMENTER", "opencode")

EXPLORER_PATTERNS = [
    r"\b(search|find|grep|locate|discover|explore|investigate|trace|list)\b",
    r"\b(welche|wo|suche|finde|entdecke|untersuche)\b",
    r"\b(read|check|inspect|verify|audit|scan)\b",
]

LIBRARIAN_PATTERNS = [
    r"\b(docs?|documentation|api|reference|manual|wiki|readme)\b",
    r"\b(search web|web search|google|research|look up)\b",
    r"\b(dependency|dependencies|package|npm|pip|cargo)\b",
]

REVIEWER_PATTERNS = [
    r"\b(review|pr|pull request|diff|verify|validate|check)\b",
    r"\b(test|tests|failing|broken|regression)\b",
    r"\b(prüfe|validiere|teste)\b",
]

IMPLEMENTER_PATTERNS = [
    r"\b(implement|fix|build|create|add|change|modify|update|refactor)\b",
    r"\b(write|edit|patch|deploy|migrate)\b",
    r"\b(erstelle|ändere|baue|fixe|implementiere)\b",
]


def classify(text: str) -> tuple[str, str]:
    lower = text.lower()

    for pattern in REVIEWER_PATTERNS:
        if re.search(pattern, lower):
            return "reviewer", DEFAULT_IMPLEMENTER

    for pattern in EXPLORER_PATTERNS:
        if re.search(pattern, lower):
            return "explorer", DEFAULT_EXPLORER

    for pattern in LIBRARIAN_PATTERNS:
        if re.search(pattern, lower):
            return "librarian", DEFAULT_EXPLORER

    for pattern in IMPLEMENTER_PATTERNS:
        if re.search(pattern, lower):
            return "implementer", DEFAULT_IMPLEMENTER

    return "explorer", DEFAULT_EXPLORER


def explain(text: str) -> str:
    role, agent = classify(text)
    return f"role={role} agent={agent} reason=pattern-match"


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("query", nargs="*")
    parser.add_argument("--explain", action="store_true")
    args = parser.parse_args()

    text = " ".join(args.query).strip()

    if not text and not sys.stdin.isatty():
        text = sys.stdin.read().strip()

    if not text:
        role, agent = "explorer", DEFAULT_EXPLORER
    else:
        role, agent = classify(text)

    if args.explain:
        print(explain(text))
    else:
        print(f"role={role} agent={agent}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
