#!/bin/bash
# verify-tokens — checks the 4-layer token-savings standard per runtime.
# Canonical policy: docs/TOKEN-SAVINGS-BEST-PRACTICES.md (issue #71).
#
# Usage: verify-tokens [--quiet]
# Exit: 0 = all compliant, 1 = one or more regressions (fail loud).
#
# Intended callers:
#   - standalone (developer runs it)
#   - sin-sync post-sync hook (fail loud on drift after a fleet sync)
#   - session-start protocol (surface non-compliance as a warning)

set -uo pipefail
QUIET="${1:-}"
FAIL=0
say()  { [ "$QUIET" = "--quiet" ] || echo -e "$1"; }
pass() { say "  ✅ $1"; }
fail() { say "  🚨 $1"; FAIL=1; }
warn() { say "  ⚠️  $1"; }

CLAUDE_SETTINGS="$HOME/.claude/settings.json"
OPENCODE_PLUGINS="$HOME/.config/opencode/plugins"
CODEX_ORCA_HOME="$HOME/Library/Application Support/orca/codex-runtime-home/home"

say "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
say "🔍 Token-Savings Standard — 4-layer compliance check"
say "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── L0: dollar-level measurement + model routing (see BEST-PRACTICES §6.2/§6.3) ──
# L0 sits below the 4 layers: it measures total spend and gates the subagent model.
say "\n[L0] baseline + model routing"
# ccusage: real $ ground truth (advisory only — a measurement, never fails the gate)
say "  ℹ️  baseline: npx ccusage@latest daily   (real \$/day; session|blocks for more)"
# subagent-model gate: Sonnet is the safe floor; Opus = silent \$ drain, unset = default Opus.
if [ -f "$CLAUDE_SETTINGS" ]; then
  SUBAGENT_MODEL="$(python3 - "$CLAUDE_SETTINGS" <<'PY' 2>/dev/null || true
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: sys.exit(0)
print(d.get('env',{}).get('CLAUDE_CODE_SUBAGENT_MODEL',''))
PY
)"
  if [ -z "$SUBAGENT_MODEL" ]; then
    fail "CLAUDE_CODE_SUBAGENT_MODEL unset — subagents default to Opus (\$ drain). Set env.CLAUDE_CODE_SUBAGENT_MODEL=claude-sonnet-5"
  elif echo "$SUBAGENT_MODEL" | grep -qi "opus"; then
    fail "CLAUDE_CODE_SUBAGENT_MODEL='$SUBAGENT_MODEL' pins Opus for subagents (~40% costlier). Use claude-sonnet-5 (safe floor)"
  else
    pass "subagent model routed to '$SUBAGENT_MODEL' (Sonnet/Haiku floor — not Opus)"
  fi
else
  warn "cannot check CLAUDE_CODE_SUBAGENT_MODEL — settings.json not found"
fi

# ── L4-input: always-loaded surface (skills + instruction files + ignore) ──
# Everything here is paid at session START, every session, before you type.
# See BEST-PRACTICES §7 (paths:-scoping, skill-sprawl budget, .claudeignore).
say "\n[L4-input] always-loaded context surface"

# Skill sprawl: each skill's name+description costs ~100 tokens at session start.
# Budget = 1% of context / 8000 chars for ALL descriptions combined.
SKILL_DIR="$HOME/.claude/skills"
if [ -d "$SKILL_DIR" ]; then
  SKILL_COUNT=$(find "$SKILL_DIR" -maxdepth 2 -name SKILL.md 2>/dev/null | wc -l | tr -d ' ')
  # sum the description: bytes across all SKILL.md (proxy for always-loaded cost)
  DESC_BYTES=$(for s in "$SKILL_DIR"/*/SKILL.md; do
    [ -f "$s" ] && awk '/^description:/{sub(/^description:[ ]*/,"");print}' "$s"
  done 2>/dev/null | wc -c | tr -d ' ')
  if [ "$SKILL_COUNT" -gt 30 ]; then
    warn "skill sprawl: $SKILL_COUNT skills (~$((SKILL_COUNT*100)) tokens at session start) — prune or use disable-model-invocation on slash-only skills"
  else
    pass "skill count ok ($SKILL_COUNT skills, ~$((SKILL_COUNT*100)) tokens always-loaded)"
  fi
  if [ "$DESC_BYTES" -gt 8000 ]; then
    warn "skill descriptions total ${DESC_BYTES}B > 8000B budget (1% of context) — tighten descriptions"
  else
    pass "skill description budget ok (${DESC_BYTES}B / 8000B)"
  fi
else
  warn "no ~/.claude/skills dir"
fi

# Instruction-file size: CLAUDE.md/AGENTS.md load every call. Warn past ~8KB
# (~2k tokens); the fix is paths:-scoped rules, not one fat always-on file.
for f in "$HOME/.claude/CLAUDE.md" "$HOME/.config/opencode/AGENTS.md" "$HOME/.codex/AGENTS.md"; do
  [ -f "$f" ] || continue
  B=$(wc -c < "$f" | tr -d ' ')
  short="$(basename "$(dirname "$f")")/$(basename "$f")"
  if [ "$B" -gt 30000 ]; then
    warn "instruction file heavy: $short = ${B}B (~$((B/4)) tokens every call) — extract reference into paths:-scoped rules"
  else
    pass "instruction file lean: $short (${B}B)"
  fi
done

# .claudeignore: blocks generated/vendored/binary noise from context.
if [ -f "$HOME/.claude/.claudeignore" ]; then
  pass ".claudeignore present (blocks node_modules/logs/graphs from context)"
else
  warn ".claudeignore missing — add one to block node_modules/*.log/graphs (BEST-PRACTICES §7)"
fi

# ── Global L1: rtk present + hook installed ──────────────────────────
say "\n[L1] rtk shell layer"
if command -v rtk >/dev/null 2>&1; then
  pass "rtk on PATH ($(rtk --version 2>/dev/null | head -1))"
  # transparent hook: rtk gain must NOT warn "No hook installed"
  if rtk gain 2>&1 | grep -qi "No hook installed"; then
    fail "rtk gain reports NO hook installed — run: rtk init -g --hook-only --auto-patch"
  else
    pass "rtk hook active (no 'No hook installed' warning)"
  fi
  # self-test the rewrite (rtk rewrite exits non-zero as its "was-rewritten" signal;
  # check the OUTPUT, not the exit code — pipefail would otherwise mask a real match)
  RW="$(rtk rewrite "git status" 2>&1 || true)"
  # Ignore macOS "Abort trap" on some rtk versions; check what we got
  RW="${RW%%Abort*}"  # strip abort output if present
  RW="$(echo "$RW" | head -1)"  # take first line only
  if [ "$RW" = "rtk git status" ]; then
    pass "rtk rewrite works (git status → rtk git status)"
  else
    warn "rtk rewrite returned '$RW' (expected 'rtk git status') — check registry"
  fi
else
  fail "rtk NOT found on PATH"
fi

# ── Claude Code ──────────────────────────────────────────────────────
# L1 hooks live in settings.json; MCP servers are merged by wow-my-zsh into
# ~/.claude.json (mcpServers) — NOT into settings.json. Counting the wrong file
# produced a false "4 servers thinned" green while 10 lived in the real config
# (issue #2). Soft budget warn until joint L2 allowlist lands (issue #3).
say "\n[Claude Code]"
CLAUDE_MCP_JSON="$HOME/.claude.json"
if [ -f "$CLAUDE_SETTINGS" ]; then
  python3 - "$CLAUDE_SETTINGS" "$CLAUDE_MCP_JSON" <<'CLAUDE_PY'
import json, os, sys
from pathlib import Path

settings_path, mcp_path = sys.argv[1], sys.argv[2]
fail = 0

try:
    d = json.load(open(settings_path))
except Exception as e:
    print(f"  🚨 settings.json invalid JSON: {e}")
    sys.exit(3)

env = d.get("env", {})
pre = d.get("hooks", {}).get("PreToolUse", [])
rtk_hook = any(
    "rtk" in x.get("command", "").lower()
    for h in pre
    for x in h.get("hooks", [])
)
if rtk_hook:
    print("  ✅ L1 rtk PreToolUse hook present")
else:
    print("  🚨 L1 rtk hook missing from PreToolUse")
    fail = 1

if "ENABLE_TOOL_SEARCH" in env:
    print(
        "  🚨 L2 ENABLE_TOOL_SEARCH is set — breaks /compact "
        "(defer_loading vs cache_control). Delete the key."
    )
    fail = 1
else:
    print("  ✅ L2 tool-search deferral off (/compact intact)")

# Real MCP SoT = ~/.claude.json (wow-my-zsh merge target)
mcp = {}
source = None
if Path(mcp_path).is_file():
    try:
        mcp = json.load(open(mcp_path)).get("mcpServers") or {}
        source = mcp_path
    except Exception as e:
        print(f"  🚨 L2 cannot parse {mcp_path}: {e}")
        fail = 1
if not mcp and isinstance(d.get("mcpServers"), dict) and d["mcpServers"]:
    mcp = d["mcpServers"]
    source = settings_path + " (legacy mcpServers)"

names = sorted(mcp.keys()) if isinstance(mcp, dict) else []
heavy = {"skyvern", "chrome-devtools", "canva"} & set(names)
SOFT_MAX = int(os.environ.get("SST_MCP_SOFT_MAX", "6"))

if not source:
    print("  ⚠️  L2 no MCP config found at ~/.claude.json or settings.json")
elif heavy:
    print(f"  ⚠️  L2 heavy MCP servers present: {sorted(heavy)} (from {source})")
else:
    print(f"  ℹ️  L2 Claude MCP source: {source}")

print(f"  ℹ️  L2 Claude always-on MCP ({len(names)}): {names if names else '[]'}")
if len(names) > SOFT_MAX:
    print(
        f"  ⚠️  L2 Claude MCP count {len(names)} > soft max {SOFT_MAX} "
        f"(set SST_MCP_SOFT_MAX or thin via wow registry — joint budget issue #3)"
    )
elif names and not heavy:
    print(f"  ✅ L2 Claude MCP within soft max ({len(names)} ≤ {SOFT_MAX})")
elif not names:
    print("  ✅ L2 Claude MCP empty (no always-on schema tax)")

sys.exit(fail)
CLAUDE_PY
  rc=$?
  [ "$rc" -ne 0 ] && FAIL=1
else
  fail "Claude Code settings.json not found"
fi

# ── L2 cross-agent MCP inventory (wow-my-zsh merge targets) ──────────
say "\n[L2] fleet MCP inventory (real configs)"
python3 - <<'FLEET_PY' || true
import json, os, re
from pathlib import Path

home = Path.home()
soft = int(os.environ.get("SST_MCP_SOFT_MAX", "6"))
heavy_set = {"skyvern", "chrome-devtools", "canva"}

def load_json(path, key):
    p = Path(path)
    if not p.is_file():
        return None, "absent"
    try:
        d = json.loads(p.read_text(encoding="utf-8"))
    except Exception as e:
        return None, f"parse-error: {e}"
    bucket = d.get(key) or {}
    if not isinstance(bucket, dict):
        return [], "ok"
    return sorted(bucket.keys()), "ok"

def load_codex_toml(path):
    p = Path(path)
    if not p.is_file():
        return None, "absent"
    text = p.read_text(encoding="utf-8", errors="replace")
    names = re.findall(
        r'(?m)^\[mcp_servers\.(?:"([^"]+)"|([A-Za-z0-9_-]+))\]',
        text,
    )
    return sorted({a or b for a, b in names}), "ok"

checks = [
    ("claude",   str(home / ".claude.json"), "mcpServers", "json"),
    ("opencode", str(home / ".config/opencode/opencode.json"), "mcp", "json"),
    ("mimo",     str(home / ".config/mimocode/mimocode.json"), "mcp", "json"),
    ("jcode",    str(home / ".jcode/mcp.json"), "mcpServers", "json"),
    ("codex",    str(home / ".codex/config.toml"), None, "toml"),
]

any_heavy = []
for agent, path, key, kind in checks:
    if kind == "toml":
        names, st = load_codex_toml(path)
    else:
        names, st = load_json(path, key)
    if st == "absent":
        print(f"  ℹ️  {agent}: config absent ({path})")
        continue
    if st != "ok":
        print(f"  ⚠️  {agent}: {st} ({path})")
        continue
    n = len(names)
    flag = ""
    hit = heavy_set & set(names)
    if hit:
        flag = f" HEAVY={sorted(hit)}"
        any_heavy.extend(sorted(hit))
    elif n > soft:
        flag = f" >soft-max={soft}"
    print(f"  ℹ️  {agent}: {n} servers{flag} → {names}")

if any_heavy:
    print(f"  ⚠️  L2 heavy servers somewhere in fleet: {sorted(set(any_heavy))}")
else:
    print("  ✅ L2 no skyvern/chrome-devtools/canva in fleet MCP configs")
FLEET_PY

# ── L3: claude-mem single shared worker/DB ───────────────────────────
say "\n[L3] shared memory (claude-mem)"
WORKERS=$(pgrep -fl "claude-mem" 2>/dev/null | grep -c "start" || true)
if [ "${WORKERS:-0}" -ge 1 ]; then
  pass "claude-mem worker running (shared by Claude Code + opencode)"
else
  warn "no claude-mem 'start' worker detected (may be idle)"
fi
if [ -f "$HOME/.claude-mem/claude-mem.db" ]; then
  pass "single DB at ~/.claude-mem/claude-mem.db"
else
  warn "claude-mem DB not found at default path"
fi

# ── opencode L1 ──────────────────────────────────────────────────────
say "\n[opencode]"
if [ -f "$OPENCODE_PLUGINS/rtk.ts" ]; then
  pass "L1 rtk plugin installed (rtk.ts)"
else
  fail "L1 rtk plugin missing — run: rtk init -g --opencode"
fi

# ── Codex L1+L4 ──────────────────────────────────────────────────────
say "\n[Codex]"
codex_ok=1
for home in "$CODEX_ORCA_HOME" "$HOME/.codex"; do
  if [ -f "$home/RTK.md" ]; then
    pass "L1 RTK.md present ($home)"
  else
    warn "L1 RTK.md missing in $home"
  fi
  if [ -f "$home/AGENTS.md" ] && grep -qi "terse" "$home/AGENTS.md" 2>/dev/null; then
    pass "L4 terse contract in AGENTS.md ($home)"
  else
    fail "L4 terse contract missing in $home/AGENTS.md"
    codex_ok=0
  fi
done

# ── Orca / sub-agent preamble ────────────────────────────────────────
# The 4-layer block can live in any of several real locations depending on
# the host. Check them all; pass if ANY carries the standard. (Previously
# this hard-coded a repo-relative Orca path that does not exist in the
# SIN-Save-Token bundle, producing a false 🚨 on an otherwise-compliant host.)
say "\n[Orca / sub-agent preamble]"
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
orca_found=0
ORCA_PREAMBLE=""
for cand in \
  "$SELF_DIR/../templates/subagent-preamble.md" \
  "$SELF_DIR/../skills/orca-sin-team/templates/prompt.md" \
  "$HOME/dev/Infra-SIN-OpenCode-Stack/skills/orca-sin-team/templates/prompt.md" \
  "$HOME/.config/opencode/skills/orca-sin-team/templates/prompt.md"; do
  if [ -f "$cand" ] && grep -qi "TOKEN-SAVINGS STANDARD" "$cand"; then
    pass "4-layer standard baked into sub-agent preamble ($cand)"
    orca_found=1
    ORCA_PREAMBLE="$cand"
    break
  fi
done
[ "$orca_found" -eq 1 ] || fail "sub-agent preamble missing TOKEN-SAVINGS STANDARD block (checked bundle + Orca template paths)"

# The Orca preamble must ALSO carry the code-intel/verify pointers so subs
# discover graphify + sin verify (same discoverability guarantee as the 4 files).
if [ -n "$ORCA_PREAMBLE" ]; then
  if grep -qi "graphify query" "$ORCA_PREAMBLE"; then
    pass "graphify pointer baked into Orca preamble"
  else
    fail "graphify pointer missing in Orca preamble ($ORCA_PREAMBLE) — subs won't query the graph before grepping"
  fi
  if grep -qi "sin verify" "$ORCA_PREAMBLE"; then
    pass "sin verify pointer baked into Orca preamble"
  else
    fail "sin verify pointer missing in Orca preamble ($ORCA_PREAMBLE) — subs won't run execution-based verification"
  fi
fi

# ── SIN-Code CLI pointer present in every instruction file ───────────
# Makes the sin tools DISCOVERABLE to every runtime without MCP schema bloat.
# If an edit ever strips the pointer (it happened before with other blocks),
# this fails loud on the next sync so no runtime silently loses the tools.
say "\n[SIN-Code CLI pointer]"
for pf in \
  "$HOME/.config/opencode/AGENTS.md" \
  "$HOME/.claude/CLAUDE.md" \
  "$HOME/.codex/AGENTS.md" \
  "$HOME/Library/Application Support/orca/codex-runtime-home/home/AGENTS.md"; do
  [ -f "$pf" ] || { warn "missing instruction file: $pf"; continue; }
  if grep -qi "sin verify" "$pf" && grep -qi "SIN-Code CLI" "$pf"; then
    pass "sin pointer present ($pf)"
  else
    fail "sin CLI pointer missing in $pf (agents can't discover sin verify/review/debt)"
  fi
done

# ── graphify: installed + pointer present (LLM-free code-graph, ~25x fewer tokens) ──
say "\n[graphify code-graph]"
if command -v graphify >/dev/null 2>&1; then
  pass "graphify on PATH"
else
  warn "graphify NOT on PATH — install: uv tool install graphifyy (then 'graphify update .')"
fi
for pf in \
  "$HOME/.config/opencode/AGENTS.md" \
  "$HOME/.claude/CLAUDE.md" \
  "$HOME/.codex/AGENTS.md" \
  "$HOME/Library/Application Support/orca/codex-runtime-home/home/AGENTS.md"; do
  [ -f "$pf" ] || continue
  if grep -qi "graphify query" "$pf"; then
    pass "graphify pointer present ($(basename "$(dirname "$pf")")/$(basename "$pf"))"
  else
    fail "graphify pointer missing in $pf (agents won't query the graph before grepping)"
  fi
done

# ── Verdict ──────────────────────────────────────────────────────────
say "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ "$FAIL" -eq 0 ]; then
  say "✅ COMPLIANT — all runtimes meet the 4-layer standard"
else
  say "🚨 REGRESSION — one or more layers non-compliant (see 🚨 above)"
fi
say "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit $FAIL
