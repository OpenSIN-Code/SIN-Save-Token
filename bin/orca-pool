#!/usr/bin/env python3
"""orca-pool — STUB: reuse warm worker sessions instead of cold-start per task.

Intended behavior (not fully implemented):
  - Maintain a small pool of already-warmed agent sessions (mimo-code/opencode).
  - `acquire` returns a session handle; `release` returns it to the pool.
  - Integrates with cache-warm so the first real task hits a warm prefix.

Usage:
  orca-pool --help
  orca-pool status
  orca-pool acquire --agent mimo-code   # stub
  orca-pool release <id>                # stub

Exit 0. No spawn in stub mode.
"""
from __future__ import annotations

import argparse
import sys


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(
        prog="orca-pool",
        description="STUB: pool of warm worker sessions (acquire/release). Not fully implemented.",
    )
    sub = ap.add_subparsers(dest="cmd")
    sub.add_parser("status", help="Show pool status (stub)")
    p_acq = sub.add_parser("acquire", help="Acquire a warm session (stub)")
    p_acq.add_argument("--agent", default="mimo-code")
    p_rel = sub.add_parser("release", help="Release a session id (stub)")
    p_rel.add_argument("id", nargs="?", default="-")
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args(argv)

    if not args.cmd:
        ap.print_help()
        print(
            "\n[stub] Full pool lifecycle not implemented. "
            "Use cache-warm + orca-router until pool lands.",
            file=sys.stderr,
        )
        return 0
    if args.cmd == "status":
        print("orca-pool: status size=0 warm=0 (stub)")
        return 0
    if args.cmd == "acquire":
        print(f"orca-pool: acquire agent={args.agent} id=stub-0 (stub — no real session)")
        return 0
    if args.cmd == "release":
        print(f"orca-pool: release id={args.id} (stub)")
        return 0
    return 0


if __name__ == "__main__":
    sys.exit(main())
