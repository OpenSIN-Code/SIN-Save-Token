#!/usr/bin/env python3
"""cache-stable-guard — warn (never block) on edits to prompt-cache prefix files.

Standalone CLI companion to hooks/cache-stable-guard.js.

Usage:
  cache-stable-guard PATH [PATH ...]     check paths; warn on busters, exit 0
  cache-stable-guard --list              list known buster patterns
  cache-stable-guard --check-cwd         scan cwd for present buster files
  echo '{"tool_name":"Write",...}' | cache-stable-guard --hook   # hook-compat
  cache-stable-guard --help

Always exit 0 (non-blocking nudge / fail-open). Warnings → stderr; silence on OK.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
from pathlib import Path

WARN = (
    "Cache-Prefix: diese Datei ist Teil des stabilen Prompt-Cache-Prefix. "
    "Änderung invalidiert den warmen Cache für alle laufenden Sessions "
    "(nächster Turn = kalt, voller Input-Preis). Sammle solche Änderungen "
    "an Session-Grenzen. (Non-blocking Nudge — Arbeit wird nicht blockiert.)"
)

BUSTER_BASENAMES = {
    "claude.md",
    "agents.md",
    "settings.json",
    "servers.json",
}

BUSTER_SUFFIXES = (
    "/shared/mcp/servers.json",
    "/mcp/servers.json",
    "/.claude/settings.json",
    "/.codex/config.toml",  # codex adjacent — report only if present
)


def is_cache_buster(p: str) -> bool:
    if not p:
        return False
    norm = p.replace("\\", "/")
    base = os.path.basename(norm).lower()
    if base in ("claude.md", "agents.md"):
        return True
    if base == "servers.json":
        return "mcp" in norm.lower() or norm.lower().endswith("servers.json")
    if base == "settings.json":
        low = norm.lower()
        return any(x in low for x in (".claude/", "claude", "codex", "opencode", "sin"))
    low = norm.lower()
    for suf in BUSTER_SUFFIXES:
        if low.endswith(suf) or suf in low:
            return True
    return False


def paths_from_hook_payload(data: dict) -> list[str]:
    out: list[str] = []
    inp = data.get("tool_input") or data.get("input") or {}
    if not isinstance(inp, dict):
        return out
    for key in (
        "file_path",
        "filePath",
        "path",
        "notebook_path",
        "notebookPath",
        "target_file",
    ):
        v = inp.get(key)
        if isinstance(v, str) and v:
            out.append(v)
    edits = inp.get("edits")
    if isinstance(edits, list):
        for e in edits:
            if isinstance(e, dict):
                for k in ("path", "file_path"):
                    v = e.get(k)
                    if isinstance(v, str) and v:
                        out.append(v)
    return out


def check_paths(paths: list[str], as_hook: bool = False) -> int:
    hits = [p for p in paths if is_cache_buster(p)]
    if not hits:
        return 0
    msg = WARN + " paths=" + ",".join(hits)
    if as_hook:
        # Claude PreToolUse shape
        payload = {
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "allow",
                "permissionDecisionReason": WARN,
            }
        }
        sys.stdout.write(json.dumps(payload))
    else:
        print(f"cache-stable-guard: WARN {msg}", file=sys.stderr)
        for p in hits:
            print(f"  buster: {p}", file=sys.stderr)
    return 0


def list_patterns() -> int:
    print("cache-stable-guard known busters:")
    for b in sorted(BUSTER_BASENAMES):
        print(f"  basename: {b}")
    for s in BUSTER_SUFFIXES:
        print(f"  suffix:   {s}")
    print("Always exit 0 — never blocks.")
    return 0


def check_cwd() -> int:
    cwd = Path.cwd()
    found: list[str] = []
    candidates = [
        "CLAUDE.md",
        "AGENTS.md",
        "settings.json",
        ".claude/settings.json",
        "shared/mcp/servers.json",
        "mcp/servers.json",
        "servers.json",
    ]
    for rel in candidates:
        p = cwd / rel
        if p.is_file() and is_cache_buster(str(p)):
            found.append(str(p))
    if not found:
        print("cache-stable-guard: no prefix buster files present in cwd")
        return 0
    print("cache-stable-guard: present prefix files (edit at session boundary):")
    for f in found:
        print(f"  {f}")
    return 0


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(
        prog="cache-stable-guard",
        description="Non-blocking warning when editing prompt-cache prefix files.",
    )
    ap.add_argument("paths", nargs="*", help="Paths to check")
    ap.add_argument("--list", action="store_true", help="List buster patterns")
    ap.add_argument("--check-cwd", action="store_true", help="List present busters in cwd")
    ap.add_argument(
        "--hook",
        action="store_true",
        help="Read Claude PreToolUse JSON from stdin; emit allow+reason if buster.",
    )
    ap.add_argument(
        "--dry-run",
        action="store_true",
        help="Same as check (no side effects ever).",
    )
    args = ap.parse_args(argv)

    try:
        if args.list:
            return list_patterns()
        if args.check_cwd:
            return check_cwd()
        if args.hook:
            raw = sys.stdin.read()
            if not raw.strip():
                return 0
            try:
                data = json.loads(raw)
            except json.JSONDecodeError:
                return 0
            tool = data.get("tool_name") or data.get("toolName") or ""
            paths = paths_from_hook_payload(data)
            if tool in ("Bash", "bash"):
                cmd = ""
                inp = data.get("tool_input") or {}
                if isinstance(inp, dict):
                    cmd = str(inp.get("command") or inp.get("cmd") or "")
                # rough: if cmd mentions buster names with write ops, warn
                low = cmd.lower()
                if any(n in low for n in ("claude.md", "agents.md", "servers.json")) or (
                    "settings.json" in low and re.search(r"claude|codex|opencode", low)
                ):
                    if re.search(r">{1,2}|tee\b|sed\s+-i|mv\b|cp\b", low):
                        paths.append(cmd)
            return check_paths(paths, as_hook=True)
        if not args.paths:
            ap.print_help()
            return 0
        return check_paths(args.paths, as_hook=False)
    except Exception as e:  # noqa: BLE001 — fail-open
        print(f"cache-stable-guard: warn (fail-open) {e}", file=sys.stderr)
        return 0


if __name__ == "__main__":
    sys.exit(main())
