#!/usr/bin/env python3
"""
sin-cache – Cache-CLI für SIN-Code.

Befehle:
  stats                    Statistiken anzeigen
  inspect <query>          Cache-Eintrag inspizieren
  invalidate --path <p>    Einträge für Pfad invalidieren
  warm --profile <p>       Cache vorwärmen
  gc                       Garbage Collection
"""

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

from sin_cache import SinCache


def command_stats(args: argparse.Namespace) -> int:
    cache = SinCache()
    stats = cache.stats(days=args.days)
    cache.close()
    print(json.dumps(stats, indent=2))
    return 0


def command_inspect(args: argparse.Namespace) -> int:
    cache = SinCache()
    result = cache.get(
        route=args.route or "code_symbol",
        provider=args.provider or "graphify",
        query=args.query,
        repository_id=args.repository_id or "all",
    )
    cache.close()

    if result is None:
        print(json.dumps({"status": "miss"}))
        return 1

    print(json.dumps(result, indent=2, default=str))
    return 0


def command_invalidate(args: argparse.Namespace) -> int:
    cache = SinCache()

    if args.path:
        count = cache.invalidate_by_path(args.path)
        print(json.dumps({"invalidated": count, "path": args.path}))
    elif args.key:
        cache.invalidate_by_key(args.key)
        print(json.dumps({"invalidated": 1, "key": args.key}))
    else:
        print("ERROR: --path or --key required", file=sys.stderr)
        cache.close()
        return 1

    cache.close()
    return 0


def command_gc(args: argparse.Namespace) -> int:
    cache = SinCache()
    removed = cache.gc(max_age_seconds=args.max_age * 86400)
    cache.close()
    print(json.dumps({"removed": removed, "max_age_days": args.max_age}))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="sin-cache",
        description="Cache-CLI für SIN-Code",
    )
    subparsers = parser.add_subparsers(dest="command")

    p_stats = subparsers.add_parser("stats", help="Statistiken")
    p_stats.add_argument("--days", type=int, default=1)

    p_inspect = subparsers.add_parser("inspect", help="Eintrag inspizieren")
    p_inspect.add_argument("query")
    p_inspect.add_argument("--route")
    p_inspect.add_argument("--provider")
    p_inspect.add_argument("--repository-id")

    p_invalidate = subparsers.add_parser("invalidate", help="Invalidieren")
    p_invalidate.add_argument("--path")
    p_invalidate.add_argument("--key")

    p_gc = subparsers.add_parser("gc", help="Garbage Collection")
    p_gc.add_argument("--max-age", type=int, default=30, help="Max age in days")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return 1

    commands = {
        "stats": command_stats,
        "inspect": command_inspect,
        "invalidate": command_invalidate,
        "gc": command_gc,
    }
    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
