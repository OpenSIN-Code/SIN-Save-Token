#!/usr/bin/env python3
"""
sin-orca v2 – Deterministischer Orchestrator für Code-Reviews und -Änderungen.

Architektur (1:1 aus User-Nachrichten):
- Controller-State außerhalb des Repositorys (~/.local/state/sin-orca/)
- Append-only Event-Log mit SHA256-Integrität
- Strukturierte Artefakte statt Roh-Transcripts
- Checkpoint-Zustandsmaschine
- Verpflichtender Blind Reviewer
- Sensible Limits (keine harten Schritt-/Befehls-Limits)
"""

import argparse
import fcntl
import hashlib
import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Optional

ZERO_HASH = "0" * 64
ALLOWED_ARTIFACTS = ["checkpoint.json", "report.json", "review.json"]
READY_PATTERN = re.compile(r"SIN_ARTIFACT_READY\s+(\S+\.json)")


# ─── Hilfsfunktionen ────────────────────────────────────────────────────────

def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def sha256_text(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def canonical_json(obj: Any) -> bytes:
    return json.dumps(obj, sort_keys=True, ensure_ascii=False, separators=(",", ":")).encode("utf-8")


def repository_root() -> Path:
    current = Path.cwd()
    for parent in [current] + list(current.parents):
        if (parent / ".git").is_dir():
            return parent
    return current


# ─── Controller-State außerhalb des Repositorys ─────────────────────────────

def repository_id() -> str:
    return sha256_text(str(repository_root()))[:20]


def state_root() -> Path:
    configured = os.environ.get("SIN_ORCA_STATE_ROOT")
    base = (
        Path(configured).expanduser()
        if configured
        else Path.home()
        / ".local"
        / "state"
        / "sin-orca"
    )
    return base / repository_id()


def task_directory(task_id: str) -> Path:
    return state_root() / task_id


def task_json_path(task_id: str) -> Path:
    return task_directory(task_id) / "task.json"


def events_path(task_id: str) -> Path:
    return task_directory(task_id) / "events.jsonl"


def ledger_path(task_id: str) -> Path:
    return task_directory(task_id) / "ledger.json"


def review_packet_path(task_id: str) -> Path:
    return task_directory(task_id) / "review-packet.json"


def prompt_path(task_id: str) -> Path:
    return task_directory(task_id) / "prompt.md"


# ─── Config ──────────────────────────────────────────────────────────────────

def load_config() -> dict[str, Any]:
    config_paths = [
        repository_root() / "config" / "orca-orchestrator.json",
        Path.home() / ".config" / "sin-orca" / "config.json",
    ]
    for path in config_paths:
        if path.exists():
            with open(path, encoding="utf-8") as f:
                return json.load(f)
    return {}


# ─── Command-Ausführung ─────────────────────────────────────────────────────

def run_command(
    cmd: list[str],
    cwd: Optional[Path] = None,
    timeout: int = 600,
) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=timeout,
        cwd=cwd,
    )


def run_orca(args: list[str]) -> dict[str, Any]:
    cmd = ["orca"] + args + ["--json"]
    result = run_command(cmd)
    if result.returncode != 0:
        raise RuntimeError(f"orca failed: {result.stderr}")
    return json.loads(result.stdout)


def output_text(result: dict[str, Any]) -> str:
    return result.get("result", {}).get("text", "")


# ─── Event-Log als Source of Truth ───────────────────────────────────────────

def read_events(task_id: str) -> list[dict[str, Any]]:
    path = events_path(task_id)
    if not path.exists():
        return []
    events = []
    with open(path, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                events.append(json.loads(line))
    return events


def reduce_events(task_id: str, events: list[dict[str, Any]]) -> dict[str, Any]:
    ledger: dict[str, Any] = {
        "task_id": task_id,
        "events_count": len(events),
        "status": "created",
        "worker": {},
        "reviewer": {},
        "verification": {},
    }
    for event in events:
        etype = event.get("type", "")
        payload = event.get("payload", {})
        if etype == "task.created":
            ledger["status"] = "created"
            ledger["task"] = payload
        elif etype == "task.dispatched":
            ledger["status"] = "dispatched"
            ledger["worker"] = payload
        elif etype == "worker.checkpoint":
            ledger["status"] = f"checkpoint:{payload.get('checkpoint', 'unknown')}"
            ledger["worker"]["checkpoint"] = payload
        elif etype == "worker.report":
            ledger["status"] = "report-received"
            ledger["worker"]["report"] = payload
        elif etype == "codex.approved":
            ledger["worker"]["last_approval"] = payload
        elif etype == "codex.interrupted":
            ledger["worker"]["last_interruption"] = payload
        elif etype == "codex.followup":
            ledger["worker"]["last_followup"] = payload
        elif etype == "codex.suspended":
            ledger["status"] = "suspended"
        elif etype == "codex.resumed":
            ledger["status"] = "resumed"
        elif etype == "codex.sent":
            ledger["worker"]["last_sent"] = payload
        elif etype == "controller.verification":
            ledger["status"] = "verification-complete"
            ledger["verification"] = payload
        elif etype == "reviewer.verdict":
            ledger["status"] = "review-received"
            ledger["reviewer"] = payload
        elif etype == "task.completed":
            ledger["status"] = "completed"
        elif etype == "task.failed":
            ledger["status"] = "failed"
            ledger["failure_reason"] = payload.get("reason", "unknown")
    return ledger


def atomic_write_json(path: Path, data: Any) -> None:
    tmp = path.with_suffix(".tmp")
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
        f.flush()
        os.fsync(f.fileno())
    tmp.rename(path)


def append_event(
    task_id: str,
    event_type: str,
    payload: dict[str, Any],
) -> dict[str, Any]:
    directory = task_directory(task_id)
    directory.mkdir(parents=True, exist_ok=True)

    lock_path = directory / ".events.lock"

    with lock_path.open("a+") as lock:
        fcntl.flock(lock.fileno(), fcntl.LOCK_EX)

        events = read_events(task_id)
        sequence = len(events) + 1

        previous_hash = (
            events[-1]["event_hash"]
            if events
            else ZERO_HASH
        )

        timestamp = utc_now()

        material = {
            "sequence": sequence,
            "type": event_type,
            "timestamp": timestamp,
            "payload": payload,
            "previous_hash": previous_hash,
        }

        event = {
            **material,
            "event_hash": hashlib.sha256(
                canonical_json(material)
            ).hexdigest(),
        }

        with events_path(task_id).open(
            "a",
            encoding="utf-8",
        ) as handle:
            handle.write(
                json.dumps(
                    event,
                    ensure_ascii=False,
                    separators=(",", ":"),
                )
                + "\n"
            )

            handle.flush()
            os.fsync(handle.fileno())

        ledger = reduce_events(
            task_id,
            [*events, event],
        )

        atomic_write_json(
            ledger_path(task_id),
            ledger,
        )

        fcntl.flock(lock.fileno(), fcntl.LOCK_UN)

    return ledger


def current_ledger(task_id: str) -> dict[str, Any]:
    path = ledger_path(task_id)
    if path.exists():
        with open(path, encoding="utf-8") as f:
            return json.load(f)
    return reduce_events(task_id, read_events(task_id))


def ensure_terminal(task_id: str, actor: str) -> str:
    ledger = current_ledger(task_id)
    terminal = ledger.get(actor, {}).get("terminal")
    if not terminal:
        raise RuntimeError(
            f"No terminal found for actor '{actor}' in task '{task_id}'"
        )
    return terminal


def actor_outbox(ledger: dict[str, Any], actor: str) -> Path:
    worktree = ledger.get(actor, {}).get("worktree_path")
    if not worktree:
        raise RuntimeError(f"No worktree for actor '{actor}'")
    return Path(worktree) / ".sin-worker" / "outbox"


def consume_artifact(task_id: str, actor: str, filename: str) -> dict[str, Any]:
    outbox = actor_outbox(current_ledger(task_id), actor)
    artifact_path = outbox / filename
    if not artifact_path.exists():
        return {"artifact": filename, "error": "not_found"}
    with open(artifact_path, encoding="utf-8") as f:
        data = json.load(f)
    artifact_path.unlink()
    return {"artifact": filename, **data}


# ─── Enforcement: Repeated Failure Detection ─────────────────────────────────

def track_command_result(
    task_id: str,
    command: str,
    exit_code: int,
    error_hash: str = "",
) -> dict[str, Any]:
    directory = task_directory(task_id)
    directory.mkdir(parents=True, exist_ok=True)

    history_path = directory / "command-history.json"

    history: list[dict[str, Any]] = []
    if history_path.exists():
        with open(history_path, encoding="utf-8") as f:
            history = json.load(f)

    entry = {
        "command": command,
        "exit_code": exit_code,
        "error_hash": error_hash,
        "timestamp": utc_now(),
    }
    history.append(entry)

    max_history = 50
    if len(history) > max_history:
        history = history[-max_history:]

    with open(history_path, "w", encoding="utf-8") as f:
        json.dump(history, f, ensure_ascii=False)

    return entry


def check_repeated_failures(
    task_id: str,
    config: dict[str, Any],
) -> dict[str, Any]:
    worker_control = config.get("worker_control", {})
    policy = worker_control.get("repeated_failure_policy", {})
    max_identical = policy.get(
        "maximum_identical_failures_without_codex_intervention", 2
    )

    history_path = task_directory(task_id) / "command-history.json"
    if not history_path.exists():
        return {"blocked": False}

    with open(history_path, encoding="utf-8") as f:
        history = json.load(f)

    if len(history) < max_identical:
        return {"blocked": False}

    recent = history[-max_identical:]

    failure_groups: dict[str, list[int]] = {}
    for i, entry in enumerate(recent):
        if entry["exit_code"] == 0:
            failure_groups.clear()
            continue

        key_parts = [
            entry.get("command", ""),
            str(entry.get("exit_code", "")),
            entry.get("error_hash", ""),
        ]
        key = "|".join(key_parts)

        if key not in failure_groups:
            failure_groups[key] = []
        failure_groups[key].append(i)

    for key, positions in failure_groups.items():
        if len(positions) >= max_identical:
            return {
                "blocked": True,
                "reason": "repeated_failure",
                "requires_codex_intervention": True,
                "identical_failures": len(positions),
                "command": key.split("|")[0],
            }

    return {"blocked": False}


# ─── Enforcement: Stalled Worker Detection ───────────────────────────────────

def update_activity_timestamp(task_id: str, actor: str) -> None:
    directory = task_directory(task_id)
    directory.mkdir(parents=True, exist_ok=True)

    activity_path = directory / "activity.json"
    activity: dict[str, Any] = {}
    if activity_path.exists():
        with open(activity_path, encoding="utf-8") as f:
            activity = json.load(f)

    activity[f"{actor}_last_active"] = utc_now()
    activity[f"{actor}_last_activity_type"] = "poll"

    with open(activity_path, "w", encoding="utf-8") as f:
        json.dump(activity, f, ensure_ascii=False)


def check_stalled_worker(
    task_id: str,
    actor: str,
    config: dict[str, Any],
) -> dict[str, Any]:
    worker_control = config.get("worker_control", {})
    policy = worker_control.get("stalled_worker_policy", {})

    if not policy.get("enabled", True):
        return {"stalled": False}

    max_inactive = policy.get("maximum_inactive_seconds", 1200)

    activity_path = task_directory(task_id) / "activity.json"
    if not activity_path.exists():
        return {"stalled": False}

    with open(activity_path, encoding="utf-8") as f:
        activity = json.load(f)

    last_active_str = activity.get(f"{actor}_last_active")
    if not last_active_str:
        return {"stalled": False}

    try:
        last_active = datetime.fromisoformat(last_active_str)
    except (ValueError, TypeError):
        return {"stalled": False}

    now = datetime.now(timezone.utc)
    inactive_seconds = (now - last_active).total_seconds()

    if inactive_seconds < max_inactive:
        return {"stalled": False}

    child_running = activity.get(f"{actor}_child_process_running", False)
    if policy.get("ignore_while_child_process_running", True) and child_running:
        return {"stalled": False}

    return {
        "stalled": True,
        "idle_seconds": int(inactive_seconds),
        "action_required": "inspect_or_interrupt",
    }


# ─── Poll Actor (keine Roh-Transcripts mehr) ────────────────────────────────

def poll_actor(
    task_id: str,
    actor: str,
    limit: int,
) -> dict[str, Any]:
    ledger = current_ledger(task_id)
    terminal = ensure_terminal(task_id, actor)

    command = [
        "terminal",
        "read",
        "--terminal",
        terminal,
        "--limit",
        str(limit),
    ]

    cursor = ledger.get(f"{actor}_cursor")

    if isinstance(cursor, str) and cursor:
        command.extend(["--cursor", cursor])

    result = run_orca(command)
    text = output_text(result)

    markers = READY_PATTERN.findall(text)

    outbox = actor_outbox(
        current_ledger(task_id),
        actor,
    )

    available = [
        name
        for name in ALLOWED_ARTIFACTS
        if (outbox / name).is_file()
    ]

    updates = []

    for filename in sorted(
        set(markers) | set(available)
    ):
        updates.append(
            consume_artifact(
                task_id,
                actor,
                filename,
            )
        )

    update_activity_timestamp(task_id, actor)

    config = load_config()

    repeated = check_repeated_failures(task_id, config)
    stalled = check_stalled_worker(task_id, actor, config)

    warnings = []
    if repeated.get("blocked"):
        append_event(task_id, "worker.blocked", repeated)
        warnings.append(repeated)
    if stalled.get("stalled"):
        append_event(task_id, "worker.stalled", stalled)
        warnings.append(stalled)

    return {
        "actor": actor,
        "updates": updates,
        "discarded_terminal_chars": len(text),
        "warnings": warnings,
    }


# ─── Tatsächliche Git-Dateien (nicht aus Worker-Report) ─────────────────────

def actual_changed_files(
    task: dict[str, Any],
    ledger: dict[str, Any],
) -> list[str]:
    worktree = Path(
        ledger["worker"]["worktree_path"]
    )

    tracked = run_command(
        [
            "git",
            "diff",
            "--name-only",
            "--no-renames",
            task["base_sha"],
            "--",
        ],
        cwd=worktree,
    )

    untracked = run_command(
        [
            "git",
            "ls-files",
            "--others",
            "--exclude-standard",
        ],
        cwd=worktree,
    )

    changed = {
        line.strip()
        for line in (
            tracked.stdout
            + "\n"
            + untracked.stdout
        ).splitlines()
        if line.strip()
        and not line.strip().startswith(
            ".sin-worker/"
        )
    }

    return sorted(changed)


# ─── Controller-eigene Verifikation ──────────────────────────────────────────

def verify_in_worktree(
    task_id: str,
    command: Optional[str] = None,
    timeout: int = 600,
) -> dict[str, Any]:
    ledger = current_ledger(task_id)
    worktree = Path(
        ledger.get("worker", {}).get("worktree_path", "")
    )
    config = load_config()
    verification = config.get("verification", {})
    max_output = verification.get("maximum_output_chars", 4000)

    cmd = command or ledger.get("task", {}).get("verify_command")
    if not cmd:
        return {"ok": False, "error": "no_verify_command"}

    argv = cmd.split()
    result = run_command(argv, cwd=worktree, timeout=timeout)

    output_tail = (
        result.stdout[-max_output:]
        if len(result.stdout) > max_output
        else result.stdout
    )
    output_hash = sha256_text(result.stdout)
    ok = result.returncode == 0

    verification_result = {
        "ok": ok,
        "results": [
            {
                "argv": argv,
                "exit_code": result.returncode,
                "output_tail": output_tail,
                "output_sha256": output_hash,
            }
        ],
    }

    append_event(task_id, "controller.verification", verification_result)
    return verification_result


# ─── Command-Handler ─────────────────────────────────────────────────────────

def command_doctor(args: argparse.Namespace) -> int:
    print("sin-orca v2 – Deterministischer Orchestrator")
    print(f"State-Root: {state_root()}")
    print(f"Repository: {repository_root()}")
    print(f"Repository-ID: {repository_id()}")
    config = load_config()
    if config:
        print("Config: geladen")
    else:
        print("Config: keine gefunden (Standardwerte)")
    return 0


def command_dispatch(args: argparse.Namespace) -> int:
    task_id = f"{args.role}-{hashlib.sha256(args.objective.encode()).hexdigest()[:8]}"

    task = {
        "role": args.role,
        "objective": args.objective,
        "steps": args.step or [],
        "allowed_paths": args.allowed_path or [],
        "forbidden_paths": args.forbidden_path or [],
        "acceptance": args.acceptance or [],
        "verify_command": args.verify_command,
        "non_goals": args.non_goal or [],
        "constraints": args.constraint,
        "base_sha": "HEAD",
        "created_at": utc_now(),
    }

    atomic_write_json(task_json_path(task_id), task)

    with open(prompt_path(task_id), "w", encoding="utf-8") as f:
        f.write(f"# Task: {args.role}\n\n")
        f.write(f"## Objective\n{args.objective}\n\n")
        if args.step:
            f.write("## Steps\n")
            for i, step in enumerate(args.step, 1):
                f.write(f"{i}. {step}\n")
            f.write("\n")
        if args.allowed_path:
            f.write("## Allowed Paths\n")
            for p in args.allowed_path:
                f.write(f"- {p}\n")
            f.write("\n")
        if args.forbidden_path:
            f.write("## Forbidden Paths\n")
            for p in args.forbidden_path:
                f.write(f"- {p}\n")
            f.write("\n")
        if args.acceptance:
            f.write("## Acceptance Criteria\n")
            for ac in args.acceptance:
                f.write(f"- {ac}\n")
            f.write("\n")
        if args.constraint:
            f.write(f"## Constraints\n{args.constraint}\n\n")

    ledger = append_event(task_id, "task.created", task)
    print(json.dumps({"task_id": task_id, "status": "created"}, indent=2))
    return 0


def command_approve(args: argparse.Namespace) -> int:
    payload = {
        "step_id": args.step,
        "instruction": args.instruction,
    }
    ledger = append_event(args.task_id, "codex.approved", payload)

    terminal = ensure_terminal(args.task_id, "worker")
    message = f"CODEX APPROVED. Step {args.step}. {args.instruction}"
    run_orca(["terminal", "send", "--terminal", terminal, "--text", message, "--enter"])

    print(json.dumps({"status": "approved", "step": args.step}))
    return 0


def command_send(args: argparse.Namespace) -> int:
    terminal = ensure_terminal(args.task_id, "worker")
    run_orca(["terminal", "send", "--terminal", terminal, "--text", args.text, "--enter"])
    append_event(args.task_id, "codex.sent", {"text": args.text})
    print(json.dumps({"status": "sent"}))
    return 0


def command_interrupt(args: argparse.Namespace) -> int:
    terminal = ensure_terminal(args.task_id, "worker")

    interrupted = False
    try:
        run_orca([
            "terminal",
            "send",
            "--terminal",
            terminal,
            "--text",
            "\u0003",
        ])
        interrupted = True
        time.sleep(0.25)
    except RuntimeError:
        interrupted = False

    message = (
        "CODEX INTERRUPT. "
        "Stop current work immediately. "
        + args.text
    )

    run_orca([
        "terminal",
        "send",
        "--terminal",
        terminal,
        "--text",
        message,
        "--enter",
    ])

    append_event(
        args.task_id,
        "codex.interrupted",
        {
            "text": args.text,
            "control_c_sent": interrupted,
        },
    )

    print(json.dumps({"status": "interrupted", "control_c_sent": interrupted}))
    return 0


def command_followup(args: argparse.Namespace) -> int:
    payload = {
        "step_id": args.step,
        "instruction": args.text,
    }
    ledger = append_event(args.task_id, "codex.followup", payload)

    terminal = ensure_terminal(args.task_id, "worker")
    message = f"CODEX FOLLOWUP. Step {args.step}. {args.text}"
    run_orca(["terminal", "send", "--terminal", terminal, "--text", message, "--enter"])

    print(json.dumps({"status": "followup_sent", "step": args.step}))
    return 0


def command_suspend(args: argparse.Namespace) -> int:
    ledger = current_ledger(args.task_id)
    status = ledger.get("status", "")

    safe = (
        status.startswith("checkpoint:")
        or status in {
            "report-received",
            "review-received",
            "verification-complete",
        }
    )

    if not safe:
        print(
            "ERROR: suspend is allowed only at a controller "
            "safe point; interrupt first",
            file=sys.stderr,
        )
        return 1

    append_event(args.task_id, "codex.suspended", {"reason": args.reason})
    print(json.dumps({"status": "suspended", "reason": args.reason}))
    return 0


def command_resume(args: argparse.Namespace) -> int:
    append_event(args.task_id, "codex.resumed", {"instruction": args.text})

    terminal = ensure_terminal(args.task_id, "worker")
    message = f"CODEX RESUME. {args.text}"
    run_orca(["terminal", "send", "--terminal", terminal, "--text", message, "--enter"])

    print(json.dumps({"status": "resumed"}))
    return 0


def command_wait(args: argparse.Namespace) -> int:
    terminal = ensure_terminal(args.task_id, args.actor)
    result = run_orca([
        "terminal",
        "wait",
        "--terminal",
        terminal,
        "--for",
        "tui-idle",
        "--timeout-ms",
        "300000",
    ])
    print(json.dumps({"status": "waited", "actor": args.actor}))
    return 0


def command_mailbox(args: argparse.Namespace) -> int:
    ledger = current_ledger(args.task_id)
    terminal = ensure_terminal(args.task_id, args.actor)

    result = run_orca([
        "terminal",
        "read",
        "--terminal",
        terminal,
        "--limit",
        "5000",
    ])
    text = output_text(result)

    markers = READY_PATTERN.findall(text)

    outbox = actor_outbox(ledger, args.actor)
    available = [
        name
        for name in ALLOWED_ARTIFACTS
        if (outbox / name).is_file()
    ]

    updates = []
    for filename in sorted(set(markers) | set(available)):
        updates.append(consume_artifact(args.task_id, args.actor, filename))

    mailbox = {
        "task_id": args.task_id,
        "actor": args.actor,
        "updates": updates,
        "discarded_terminal_chars": len(text),
    }

    print(json.dumps(mailbox, indent=2))
    return 0


def command_verify(args: argparse.Namespace) -> int:
    result = verify_in_worktree(args.task_id, args.command)
    print(json.dumps(result, indent=2))
    return 0 if result.get("ok") else 1


def command_review(args: argparse.Namespace) -> int:
    ledger = current_ledger(args.task_id)
    task = ledger.get("task", {})
    worktree = Path(
        ledger.get("worker", {}).get("worktree_path", "")
    )
    base_sha = task.get("base_sha", "HEAD")

    changed_files = actual_changed_files(task, ledger)

    diff_result = run_command(
        ["git", "diff", "--no-color", base_sha, "--"],
        cwd=worktree,
    )
    bounded_diff = diff_result.stdout[:60000]

    config = load_config()
    review_config = config.get("review", {})
    preferred_agents = review_config.get(
        "preferred_agents", ["opencode", "mimo-code"]
    )

    review_packet = {
        "original_task": task,
        "base_sha": base_sha,
        "changed_files": changed_files,
        "bounded_diff": bounded_diff,
        "controller_test_results": ledger.get("verification", {}),
        "acceptance_criteria": task.get("acceptance", []),
    }

    atomic_write_json(review_packet_path(args.task_id), review_packet)

    print(json.dumps({
        "status": "review_packet_created",
        "changed_files": len(changed_files),
        "diff_chars": len(bounded_diff),
        "preferred_agents": preferred_agents,
    }, indent=2))
    return 0


def command_complete(args: argparse.Namespace) -> int:
    ledger = current_ledger(args.task_id)
    task = ledger.get("task", {})

    checks = {
        "worker_report_exists": bool(
            ledger.get("worker", {}).get("report")
        ),
        "verification_ok": ledger.get("verification", {}).get(
            "ok", False
        ),
        "reviewer_exists": bool(
            ledger.get("reviewer", {}).get("verdict")
        ),
        "review_accept": ledger.get("reviewer", {}).get("verdict")
        == "accept",
        "changed_files_in_scope": all(
            f in task.get("allowed_paths", [])
            for f in actual_changed_files(task, ledger)
        )
        if task.get("allowed_paths")
        else True,
    }

    all_ok = all(checks.values())

    if not all_ok:
        failed = [k for k, v in checks.items() if not v]
        print(json.dumps(
            {"status": "incomplete", "failed_checks": failed},
            indent=2,
        ))
        return 1

    append_event(args.task_id, "task.completed", {"checks": checks})
    print(json.dumps(
        {"status": "completed", "checks": checks},
        indent=2,
    ))
    return 0


def command_rebuild(args: argparse.Namespace) -> int:
    events = read_events(args.task_id)
    ledger = reduce_events(args.task_id, events)
    atomic_write_json(ledger_path(args.task_id), ledger)
    print(json.dumps(
        {"status": "rebuilt", "events_count": len(events)},
        indent=2,
    ))
    return 0


# ─── Main ────────────────────────────────────────────────────────────────────

def main() -> int:
    parser = argparse.ArgumentParser(
        prog="sin-orca",
        description="Deterministischer Orchestrator v2",
    )
    subparsers = parser.add_subparsers(dest="command")

    subparsers.add_parser("doctor", help="System-Check")

    p_dispatch = subparsers.add_parser("dispatch", help="Task erstellen")
    p_dispatch.add_argument("--role", required=True)
    p_dispatch.add_argument("--objective", required=True)
    p_dispatch.add_argument("--step", action="append")
    p_dispatch.add_argument("--allowed-path", action="append")
    p_dispatch.add_argument("--forbidden-path", action="append")
    p_dispatch.add_argument("--acceptance", action="append")
    p_dispatch.add_argument("--verify-command")
    p_dispatch.add_argument("--non-goal", action="append")
    p_dispatch.add_argument("--constraint")

    p_approve = subparsers.add_parser("approve", help="Schritt freigeben")
    p_approve.add_argument("task_id")
    p_approve.add_argument("--step", required=True)
    p_approve.add_argument("--instruction", required=True)

    p_send = subparsers.add_parser("send", help="Nachricht senden")
    p_send.add_argument("task_id")
    p_send.add_argument("--text", required=True)

    p_interrupt = subparsers.add_parser("interrupt", help="Unterbrechen")
    p_interrupt.add_argument("task_id")
    p_interrupt.add_argument("--text", required=True)

    p_followup = subparsers.add_parser("followup", help="Follow-up")
    p_followup.add_argument("task_id")
    p_followup.add_argument("--step", required=True)
    p_followup.add_argument("--text", required=True)

    p_suspend = subparsers.add_parser(
        "suspend", help="Suspend at safe point"
    )
    p_suspend.add_argument("task_id")
    p_suspend.add_argument("--reason", required=True)

    p_resume = subparsers.add_parser(
        "resume", help="Resume workflow"
    )
    p_resume.add_argument("task_id")
    p_resume.add_argument("--text", required=True)

    p_wait = subparsers.add_parser("wait", help="Auf Worker warten")
    p_wait.add_argument("task_id")
    p_wait.add_argument("--actor", default="worker")

    p_mailbox = subparsers.add_parser(
        "mailbox", help="Mailbox abholen"
    )
    p_mailbox.add_argument("task_id")
    p_mailbox.add_argument("--actor", default="worker")

    p_verify = subparsers.add_parser(
        "verify", help="Verifikation ausführen"
    )
    p_verify.add_argument("task_id")
    p_verify.add_argument("--command")

    p_review = subparsers.add_parser(
        "review", help="Blind Review starten"
    )
    p_review.add_argument("task_id")

    p_complete = subparsers.add_parser(
        "complete", help="Task abschließen"
    )
    p_complete.add_argument("task_id")

    p_rebuild = subparsers.add_parser(
        "rebuild", help="Ledger rekonstruieren"
    )
    p_rebuild.add_argument("task_id")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return 1

    commands = {
        "doctor": command_doctor,
        "dispatch": command_dispatch,
        "approve": command_approve,
        "send": command_send,
        "interrupt": command_interrupt,
        "followup": command_followup,
        "suspend": command_suspend,
        "resume": command_resume,
        "wait": command_wait,
        "mailbox": command_mailbox,
        "verify": command_verify,
        "review": command_review,
        "complete": command_complete,
        "rebuild": command_rebuild,
    }
    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
