#!/usr/bin/env python3
"""SIN context broker.

One query enters. At most one provider normally wins.
The broker prevents agents from querying every memory and code system in sequence.
"""

from __future__ import annotations

import argparse
import atexit
import hashlib
import importlib.util
import json
import os
import re
import shlex
import sqlite3
import subprocess
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parent.parent
LIB = ROOT / "lib"
if str(LIB) not in sys.path:
    sys.path.insert(0, str(LIB))

from sin_context.evidence_firewall import render_for_model, wrap_evidence  # noqa: E402
from sin_context.provider_runtime import (  # noqa: E402
    ProviderRuntime,
    ProviderSpec,
    load_provider_specs,
)

DEFAULT_POLICY = ROOT / "config" / "context-policy.json"
DEFAULT_PROVIDER_CONFIG = ROOT / "config" / "provider-runtime.json"
DEFAULT_CACHE = Path.home() / ".cache" / "sin-save-token" / "context.sqlite3"
DEFAULT_PROVIDER_HEALTH = Path.home() / ".cache" / "sin" / "provider-health.sqlite3"

WORD_PATTERN = re.compile(r"[A-Za-zÀ-ÿ0-9_]+")


@dataclass(frozen=True)
class ProviderResult:
    provider: str
    text: str
    score: float = 1.0


@dataclass(frozen=True)
class CachedResult:
    provider: str
    text: str
    is_negative: bool


@dataclass(frozen=True)
class ProviderOutcome:
    result: ProviderResult | None
    status: str
    cache_negative: bool = False
    duration_ms: int | None = None


def safe_subprocess_environment() -> dict[str, str]:
    environment = os.environ.copy()
    environment.pop("SIN_MANIFEST_HMAC_KEY", None)
    return environment


def file_sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def load_policy(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as handle:
        policy = json.load(handle)
    validate_policy(policy)
    return policy


def validate_policy(policy: dict[str, Any]) -> None:
    if not isinstance(policy, dict):
        raise ValueError("context policy must be an object")
    budgets = policy.get("budgets")
    retrieval = policy.get("retrieval")
    routes = policy.get("routes")
    if not isinstance(budgets, dict) or not isinstance(retrieval, dict):
        raise ValueError("context policy requires budgets and retrieval objects")
    if not isinstance(routes, list) or not routes:
        raise ValueError("context policy requires non-empty routes")

    maximum_tokens = budgets.get("maximum_tokens")
    if (
        not isinstance(maximum_tokens, int)
        or isinstance(maximum_tokens, bool)
        or not 1 <= maximum_tokens <= 100_000
    ):
        raise ValueError("maximum_tokens is invalid")
    for name, value in budgets.items():
        if (
            not isinstance(value, int)
            or isinstance(value, bool)
            or not 1 <= value <= maximum_tokens
        ):
            raise ValueError(f"budget {name!r} is invalid")

    maximum_attempts = retrieval.get("maximum_provider_attempts")
    if (
        not isinstance(maximum_attempts, int)
        or isinstance(maximum_attempts, bool)
        or not 1 <= maximum_attempts <= 5
    ):
        raise ValueError("maximum_provider_attempts is invalid")
    for field in ("cache_ttl_seconds", "negative_cache_ttl_seconds"):
        value = retrieval.get(field)
        if (
            not isinstance(value, int)
            or isinstance(value, bool)
            or not 0 <= value <= 7 * 24 * 60 * 60
        ):
            raise ValueError(f"{field} is invalid")

    names: set[str] = set()
    for route in routes:
        if not isinstance(route, dict):
            raise ValueError("route entries must be objects")
        name = route.get("name")
        patterns = route.get("patterns")
        providers = route.get("providers")
        budget = route.get("budget")
        if not isinstance(name, str) or not name or name in names:
            raise ValueError("route names must be unique non-empty strings")
        names.add(name)
        if not isinstance(patterns, list) or not patterns or not all(
            isinstance(pattern, str) and pattern for pattern in patterns
        ):
            raise ValueError(f"route {name!r} has invalid patterns")
        for pattern in patterns:
            re.compile(pattern)
        if not isinstance(providers, list) or not providers or not all(
            isinstance(provider, str) and provider for provider in providers
        ):
            raise ValueError(f"route {name!r} has invalid providers")
        if len(providers) != len(set(providers)):
            raise ValueError(f"route {name!r} repeats a provider")
        if budget not in budgets:
            raise ValueError(f"route {name!r} references unknown budget")


def approximate_tokens(text: str) -> int:
    return max(1, (len(text) + 2) // 3)


def truncate_to_tokens(text: str, limit: int) -> str:
    if approximate_tokens(text) <= limit:
        return text.strip()
    char_limit = max(1, limit * 3)
    clipped = text[:char_limit]
    last_newline = clipped.rfind("\n")
    if last_newline > char_limit * 0.65:
        clipped = clipped[:last_newline]
    return clipped.rstrip() + "\n[… context budget reached]"


def normalize_query(query: str) -> str:
    return re.sub(r"\s+", " ", query.strip().lower())


def repository_fingerprint(cwd: str) -> str:
    """Return a cheap repository-state fingerprint."""
    try:
        environment = safe_subprocess_environment()
        head = subprocess.run(
            ["git", "rev-parse", "HEAD"],
            cwd=cwd, text=True, capture_output=True, timeout=3, check=False,
            env=environment,
        )
        status = subprocess.run(
            ["git", "status", "--porcelain=v1", "--untracked-files=normal"],
            cwd=cwd, text=True, capture_output=True, timeout=3, check=False,
            env=environment,
        )
    except (OSError, subprocess.TimeoutExpired):
        return "not-a-git-repository"
    if head.returncode != 0:
        return "not-a-git-repository"
    material = head.stdout.strip() + "\n" + status.stdout.strip()
    return hashlib.sha256(material.encode("utf-8")).hexdigest()[:20]


def cache_key(
    route: str,
    provider: str,
    query: str,
    cwd: str,
    budget: int | None = None,
    *,
    policy_fingerprint: str = "legacy-policy",
    provider_fingerprint: str = "legacy-provider",
) -> str:
    canonical = {
        "route": route,
        "provider": provider,
        "query": normalize_query(query),
        "repository": os.path.realpath(cwd),
        "repository_fingerprint": repository_fingerprint(cwd),
        "evidence_firewall_version": 2,
        "token_budget": budget,
        "policy_fingerprint": policy_fingerprint,
        "provider_fingerprint": provider_fingerprint,
    }
    raw = json.dumps(canonical, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()


def lexical_signature(text: str) -> set[str]:
    return {word.lower() for word in WORD_PATTERN.findall(text) if len(word) >= 3}


def lexical_similarity(left: str, right: str) -> float:
    left_words = lexical_signature(left)
    right_words = lexical_signature(right)
    if not left_words or not right_words:
        return 0.0
    return len(left_words & right_words) / len(left_words | right_words)


def deduplicate_sections(text: str, *, similarity_threshold: float = 0.82) -> str:
    raw_sections = re.split(r"\n{2,}", text)
    accepted: list[str] = []
    for raw_section in raw_sections:
        section = raw_section.strip()
        if not section:
            continue
        duplicate = any(lexical_similarity(section, existing) >= similarity_threshold for existing in accepted)
        if not duplicate:
            accepted.append(section)
    return "\n\n".join(accepted)


class ContextCache:
    def __init__(self, path: Path) -> None:
        path = path.expanduser().resolve()
        path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
        try:
            path.parent.chmod(0o700)
        except OSError:
            pass
        self.path = path
        self.connection = sqlite3.connect(path, timeout=10)
        self.connection.execute("PRAGMA journal_mode=WAL")
        self.connection.execute("PRAGMA synchronous=FULL")
        self.connection.execute("PRAGMA busy_timeout=10000")
        self.connection.execute("""
            CREATE TABLE IF NOT EXISTS context_cache (
                cache_key TEXT PRIMARY KEY,
                provider TEXT NOT NULL,
                value TEXT NOT NULL,
                is_negative INTEGER NOT NULL DEFAULT 0,
                created_at INTEGER NOT NULL
            )
        """)
        self.connection.commit()
        try:
            path.chmod(0o600)
        except OSError:
            pass

    def close(self) -> None:
        connection = getattr(self, "connection", None)
        if connection is not None:
            connection.close()
            self.connection = None

    def get(self, key: str, ttl: int, negative_ttl: int) -> CachedResult | None:
        row = self.connection.execute(
            "SELECT provider, value, is_negative, created_at FROM context_cache WHERE cache_key = ?",
            (key,),
        ).fetchone()
        if row is None:
            return None
        provider, value, is_negative, created_at = row
        effective_ttl = negative_ttl if is_negative else ttl
        if int(time.time()) - int(created_at) > effective_ttl:
            self.connection.execute("DELETE FROM context_cache WHERE cache_key = ?", (key,))
            self.connection.commit()
            return None
        return CachedResult(provider=provider, text=value, is_negative=bool(is_negative))

    def put(self, key: str, result: ProviderResult | None, *, provider: str) -> None:
        is_negative = result is None
        value = "" if result is None else result.text
        self.connection.execute(
            """INSERT INTO context_cache(cache_key, provider, value, is_negative, created_at)
            VALUES (?, ?, ?, ?, ?)
            ON CONFLICT(cache_key) DO UPDATE SET
                provider=excluded.provider, value=excluded.value,
                is_negative=excluded.is_negative, created_at=excluded.created_at""",
            (key, provider, value, 1 if is_negative else 0, int(time.time())),
        )
        self.connection.commit()


def with_argv(spec: ProviderSpec, argv: list[str]) -> ProviderSpec:
    """Clone a provider spec while preserving its health policy."""
    return ProviderSpec(
        name=spec.name,
        argv=argv,
        timeout_seconds=spec.timeout_seconds,
        maximum_output_chars=spec.maximum_output_chars,
        failure_threshold=spec.failure_threshold,
        cooldown_seconds=spec.cooldown_seconds,
    )


def call_runtime_provider(
    provider_name: str,
    *,
    cwd: str,
    variables: dict[str, str],
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
    argv_override: list[str] | None = None,
) -> ProviderOutcome:
    spec = specs.get(provider_name)
    if spec is None:
        return ProviderOutcome(None, "unconfigured")

    if argv_override is not None:
        spec = with_argv(spec, argv_override)

    try:
        raw = runtime.call(
            spec,
            cwd=Path(cwd).resolve(),
            variables=variables,
        )
    except (OSError, ValueError) as error:
        return ProviderOutcome(None, f"configuration-error:{error}")

    status = str(raw.get("status", "unknown"))
    duration_ms = raw.get("duration_ms")
    if raw.get("ok") is not True:
        return ProviderOutcome(
            None,
            status,
            cache_negative=False,
            duration_ms=int(duration_ms) if duration_ms is not None else None,
        )

    output = str(raw.get("output", "")).strip()
    if not output:
        return ProviderOutcome(
            None,
            "empty",
            cache_negative=True,
            duration_ms=int(duration_ms) if duration_ms is not None else None,
        )

    return ProviderOutcome(
        ProviderResult(provider_name, output),
        "completed",
        cache_negative=False,
        duration_ms=int(duration_ms) if duration_ms is not None else None,
    )


def provider_graphify(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    return call_runtime_provider(
        "graphify",
        cwd=cwd,
        variables={"query": query},
        runtime=runtime,
        specs=specs,
    )


def provider_simone(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    command = os.environ.get("SIN_SIMONE_QUERY_COMMAND", "").strip()
    argv_override = None
    if command:
        argv = shlex.split(command)
        if not argv:
            return ProviderOutcome(None, "configuration-error:empty-simone-command")
        argv_override = [*argv, "{query}"]

    return call_runtime_provider(
        "simone",
        cwd=cwd,
        variables={"query": query},
        runtime=runtime,
        specs=specs,
        argv_override=argv_override,
    )


def provider_gitnexus(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    local_adapter = ROOT / "bin" / "gitnexus-query"
    argv_override = (
        [sys.executable, str(local_adapter), "{query}"]
        if local_adapter.is_file()
        else None
    )
    return call_runtime_provider(
        "gitnexus",
        cwd=cwd,
        variables={"query": query},
        runtime=runtime,
        specs=specs,
        argv_override=argv_override,
    )


def provider_sin_code(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    return call_runtime_provider(
        "sin-code",
        cwd=cwd,
        variables={"query": query},
        runtime=runtime,
        specs=specs,
    )


def provider_cognee(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    return call_runtime_provider(
        "cognee",
        cwd=cwd,
        variables={"query": query},
        runtime=runtime,
        specs=specs,
    )


def provider_session_digest(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    del query
    local_binary = ROOT / "bin" / "session-digest"
    argv_override = [str(local_binary), "--latest"] if local_binary.exists() else None
    return call_runtime_provider(
        "session-digest",
        cwd=cwd,
        variables={},
        runtime=runtime,
        specs=specs,
        argv_override=argv_override,
    )


def provider_agent_grep(
    query: str,
    cwd: str,
    runtime: ProviderRuntime,
    specs: dict[str, ProviderSpec],
) -> ProviderOutcome:
    candidates = re.findall(r"[A-Za-z_][A-Za-z0-9_.:/-]{2,}", query)
    stop = {
        "where", "what", "which", "when", "code", "file", "function",
        "class", "warum", "welche", "wo", "datei", "funktion",
    }
    terms = [term for term in candidates if term.lower() not in stop]
    pattern = terms[-1] if terms else query
    local_binary = ROOT / "bin" / "agent-grep"
    argv_override = (
        [str(local_binary), "{pattern}", "."]
        if local_binary.exists()
        else None
    )
    return call_runtime_provider(
        "agent-grep",
        cwd=cwd,
        variables={"pattern": pattern},
        runtime=runtime,
        specs=specs,
        argv_override=argv_override,
    )


PROVIDERS = {
    "graphify": provider_graphify,
    "gitnexus": provider_gitnexus,
    "simone": provider_simone,
    "sin-code": provider_sin_code,
    "cognee": provider_cognee,
    "session-digest": provider_session_digest,
    "agent-grep": provider_agent_grep,
}


def select_route(query: str, policy: dict[str, Any]) -> dict[str, Any]:
    for route in policy["routes"]:
        for pattern in route["patterns"]:
            if re.search(pattern, query, flags=re.IGNORECASE):
                return route
    raise RuntimeError("Policy contains no fallback route")


def render_provider_evidence(
    result: ProviderResult,
    *,
    route: str,
    token_budget: int,
) -> str:
    envelope = wrap_evidence(
        source=result.provider,
        source_type="provider-output",
        content=result.text,
        trust_level="external-untrusted",
        metadata={"route": route},
    )
    maximum_chars = min(
        len(result.text),
        max(0, token_budget * 3 - 1200),
    )

    while True:
        rendered = render_for_model(
            envelope,
            maximum_chars=maximum_chars,
        )
        if approximate_tokens(rendered) <= token_budget:
            return rendered
        if maximum_chars == 0:
            return rendered
        maximum_chars = max(
            0,
            maximum_chars
            - max(
                256,
                (approximate_tokens(rendered) - token_budget) * 3,
            ),
        )


def useful(result: ProviderResult | None) -> bool:
    if result is None:
        return False
    stripped = result.text.strip()
    if len(stripped) < 20:
        return False
    negative_markers = ("no results", "not found", "keine treffer", "nothing found", "0 matches")
    lowered = stripped.lower()
    return not any(marker in lowered for marker in negative_markers)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("query", nargs="+")
    parser.add_argument("--cwd", default=os.getcwd())
    parser.add_argument("--policy", type=Path, default=DEFAULT_POLICY)
    parser.add_argument(
        "--provider-config",
        type=Path,
        default=DEFAULT_PROVIDER_CONFIG,
    )
    parser.add_argument(
        "--provider-health",
        type=Path,
        default=DEFAULT_PROVIDER_HEALTH,
    )
    parser.add_argument("--cache", type=Path, default=DEFAULT_CACHE)
    parser.add_argument("--no-cache", action="store_true")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--packet", action="store_true", help="output structured context packet")
    args = parser.parse_args()

    query = " ".join(args.query).strip()
    policy_path = args.policy.expanduser().resolve()
    provider_config_path = args.provider_config.expanduser().resolve()
    try:
        policy = load_policy(policy_path)
        policy_fingerprint = file_sha256(policy_path)
        provider_fingerprint = file_sha256(provider_config_path)
    except (OSError, ValueError, json.JSONDecodeError, re.error) as error:
        print(f"invalid context policy/config: {error}", file=sys.stderr)
        return 2
    route = select_route(query, policy)

    budget_name = route["budget"]
    budget = min(int(policy["budgets"][budget_name]), int(policy["budgets"]["maximum_tokens"]))
    ttl = int(policy["retrieval"]["cache_ttl_seconds"])
    negative_ttl = int(policy["retrieval"].get("negative_cache_ttl_seconds", 300))
    maximum_attempts = int(policy["retrieval"].get("maximum_provider_attempts", 2))
    cache = ContextCache(args.cache)
    atexit.register(cache.close)

    try:
        provider_specs = load_provider_specs(provider_config_path)
    except (OSError, ValueError, json.JSONDecodeError) as error:
        print(f"invalid provider runtime config: {error}", file=sys.stderr)
        return 2
    provider_runtime = ProviderRuntime(state_path=args.provider_health)

    # Load packet builder
    packet_spec = importlib.util.spec_from_file_location(
        "sin_context_packet", ROOT / "bin" / "sin-context-packet.py"
    )
    packet_mod = importlib.util.module_from_spec(packet_spec)
    sys.modules["sin_context_packet"] = packet_mod
    packet_spec.loader.exec_module(packet_mod)

    attempted: list[str] = []
    attempt_details: list[dict[str, Any]] = []

    for provider_name in route["providers"][:maximum_attempts]:
        attempted.append(provider_name)
        provider = PROVIDERS.get(provider_name)
        if provider is None:
            attempt_details.append(
                {"provider": provider_name, "status": "unknown-provider"}
            )
            continue

        key = cache_key(
            route["name"],
            provider_name,
            query,
            args.cwd,
            budget,
            policy_fingerprint=policy_fingerprint,
            provider_fingerprint=provider_fingerprint,
        )

        cached = None
        if not args.no_cache:
            cached = cache.get(key, ttl, negative_ttl)

        if cached is not None:
            if cached.is_negative:
                attempt_details.append(
                    {"provider": provider_name, "status": "negative-cache"}
                )
                continue
            attempt_details.append(
                {"provider": provider_name, "status": "cache-hit"}
            )
            text = truncate_to_tokens(cached.text, budget)
            if args.packet:
                packet = packet_mod.build_packet(text, provider_name, route["name"], approximate_tokens(text))
                print(packet.to_json())
            elif args.json:
                payload = {
                    "route": route["name"],
                    "provider": provider_name,
                    "cached": True,
                    "approx_tokens": approximate_tokens(text),
                    "attempts": attempt_details,
                    "context": text,
                }
                print(json.dumps(payload, ensure_ascii=False))
            else:
                print(text)
            return 0

        outcome = provider(
            query,
            args.cwd,
            provider_runtime,
            provider_specs,
        )
        attempt_details.append(
            {
                "provider": provider_name,
                "status": outcome.status,
                **(
                    {"duration_ms": outcome.duration_ms}
                    if outcome.duration_ms is not None
                    else {}
                ),
            }
        )
        result = outcome.result
        if not useful(result):
            if not args.no_cache and outcome.cache_negative:
                cache.put(key, None, provider=provider_name)
            continue

        cleaned = deduplicate_sections(result.text)
        safe_text = render_provider_evidence(
            ProviderResult(
                provider=result.provider,
                text=cleaned,
                score=result.score,
            ),
            route=route["name"],
            token_budget=budget,
        )
        bounded = ProviderResult(
            provider=result.provider,
            text=safe_text,
            score=result.score,
        )

        if not args.no_cache:
            cache.put(key, bounded, provider=provider_name)

        if args.packet:
            packet = packet_mod.build_packet(bounded.text, bounded.provider, route["name"], approximate_tokens(bounded.text))
            print(packet.to_json())
        elif args.json:
            payload = {
                "route": route["name"],
                "provider": bounded.provider,
                "cached": False,
                "approx_tokens": approximate_tokens(bounded.text),
                "attempts": attempt_details,
                "context": bounded.text,
            }
            print(json.dumps(payload, ensure_ascii=False))
        else:
            print(bounded.text)
        return 0

    if args.json:
        print(
            json.dumps(
                {
                    "route": route["name"],
                    "provider": None,
                    "cached": False,
                    "attempted": attempted,
                    "attempts": attempt_details,
                    "context": "",
                }
            )
        )
    elif args.packet:
        packet = packet_mod.build_packet("", "", route["name"], 0)
        packet.uncertainty = f"No useful context found. Attempted: {', '.join(attempted)}"
        print(packet.to_json())
    else:
        print(f"# no useful context; attempted: {', '.join(attempted)}", file=sys.stderr)
    return 3


if __name__ == "__main__":
    raise SystemExit(main())
